---
import { getBlogPosts } from '../utils/sanity';

interface Props {
  currentSlug: string;
  currentTags: string[];
}
const { currentSlug, currentTags = [] } = Astro.props;

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function formatDate(dateString: string) {
  const d = new Date(dateString + (dateString.length === 10 ? 'T12:00:00Z' : ''));
  return MONTHS[d.getUTCMonth()] + ' ' + d.getUTCDate() + ', ' + d.getUTCFullYear();
}

const allPosts = await getBlogPosts();
const related = allPosts
  .filter((p: any) => p.slug !== currentSlug)
  .map((p: any) => ({
    ...p,
    score: (p.tags || []).filter((t: string) => currentTags.includes(t)).length,
  }))
  .filter((p: any) => p.score > 0)
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="bg-gray-100 px-6 py-12 lg:py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-accent font-serif mb-8">Related Posts</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map((post: any) => (
          <a href={`/blog/${post.slug}`} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
            <div class="h-36 overflow-hidden bg-gray-200">
              {post.featuredImageUrl ? (
                <img
                  src={`${post.featuredImageUrl}?w=600&auto=format`}
                  alt={post.title}
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-gray-400 text-sm">Scripture Alive</span>
                </div>
              )}
            </div>
            <div class="p-4">
              <div class="flex flex-wrap gap-1 mb-2">
                {(post.tags || []).filter((t: string) => currentTags.includes(t)).slice(0, 2).map((tag: string) => (
                  <span class="text-xs font-semibold text-accent bg-blue-50 rounded-full px-2 py-0.5">{tag}</span>
                ))}
              </div>
              <h3 class="font-serif text-base font-bold text-gray-800 leading-snug group-hover:text-accent transition-colors">{post.title}</h3>
              <p class="text-xs text-gray-500 mt-2">{post.publishedAt ? formatDate(post.publishedAt) : ''}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
