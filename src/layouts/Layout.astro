---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	jsonld?: Record<string, unknown>;
}
const {
	title,
	description = "",
	ogImage = "https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png",
	jsonld,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const navItems = [
	{ href: "/", label: "Home" },
	{
		href: "/about",
		label: "About",
		dropdown: [
			{ href: "/about", label: "About Jeremy" },
			{ href: "/endorsements", label: "Endorsements" },
		],
	},
	{ href: "/events", label: "Events" },
	{
		href: "/workshops",
		label: "Bookings",
		dropdown: [
			{ href: "/performances", label: "Performances" },
			{ href: "/workshops", label: "Bible Memory Workshops" },
			{ href: "/guestpreaching", label: "Guest Speaking" },
		],
	},
	{
		href: "/resources",
		label: "Resources",
		dropdown: [
			{ href: "/store", label: "Store" },
			{ href: "/videos", label: "Videos" },
			{ href: "/interviews", label: "Interviews" },
			{ href: "/blog", label: "Blog" },
		],
	},
	{ href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:title"       content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={title} />
  {description && <meta name="twitter:description" content={description} />}
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Roboto:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Navigation: transparent on homepage hero, solid white on all other pages -->
  <header id="site-header" class={`sticky top-0 z-50 transition-colors duration-300 ${currentPath === '/' ? 'bg-transparent' : 'bg-white shadow-sm'}`}>
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/"><img src="https://cdn.sanity.io/images/vxczpihg/production/f95c2c1a3f77a64e7803bfcdc3138cc7a28937be-200x100.webp" alt="Scripture Alive" class="h-[108px] w-auto" /></a>
      <ul class="hidden md:flex items-center gap-8">
        {navItems.map(item => (
          <li class="relative group">
            <a
              href={item.href}
              class={`text-[20px] font-medium font-sans transition-colors ${currentPath === item.href || (item.dropdown && item.dropdown.some((d: any) => currentPath === d.href)) ? 'text-primary' : 'text-gray-600 hover:text-primary'}`}
            >
              {item.label}{item.dropdown && <span class="ml-1 text-sm">▾</span>}
            </a>
            {item.dropdown && (
              <ul class="absolute left-0 top-full mt-1 w-52 bg-white shadow-lg rounded border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                {item.dropdown.map((sub: any) => (
                  <li>
                    <a
                      href={sub.href}
                      class={`block px-4 py-3 text-sm font-medium font-sans hover:bg-gray-50 hover:text-primary transition-colors ${currentPath === sub.href ? 'text-primary' : 'text-gray-700'}`}
                    >
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li>
          <a href="/book-jeremy" class="bg-primary text-black text-[20px] font-semibold font-sans px-5 py-3 rounded transition-opacity hover:opacity-90">
            Book Jeremy
          </a>
        </li>
      </ul>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600" aria-label="Menu" aria-expanded="false">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-200 shadow-md">
      <ul class="flex flex-col px-6 py-2">
        {navItems.map(item => (
          item.dropdown ? (
            <>
              <li>
                <span class="block py-3 text-sm font-semibold font-sans border-b border-gray-100 text-gray-500 uppercase tracking-wide">{item.label}</span>
              </li>
              {item.dropdown.map((sub: any) => (
                <li>
                  <a
                    href={sub.href}
                    class={`block py-2 pl-4 text-sm font-medium font-sans border-b border-gray-100 ${currentPath === sub.href ? 'text-primary' : 'text-gray-700 hover:text-primary'}`}
                  >
                    {sub.label}
                  </a>
                </li>
              ))}
            </>
          ) : (
            <li>
              <a
                href={item.href}
                class={`block py-3 text-sm font-medium font-sans border-b border-gray-100 ${currentPath === item.href ? 'text-primary' : 'text-gray-700 hover:text-primary'}`}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
        <li class="py-3">
          <a href="/book-jeremy" class="inline-block bg-primary text-black text-sm font-semibold font-sans px-4 py-2 rounded">
            Book Jeremy
          </a>
        </li>
      </ul>
    </div>
  </header>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    // On homepage only: transparent over hero, white once scrolled past
    if (window.location.pathname === '/') {
      const header = document.getElementById('site-header');
      const onScroll = () => {
        if (window.scrollY > 80) {
          header?.classList.add('bg-white', 'shadow-sm');
          header?.classList.remove('bg-transparent');
        } else {
          header?.classList.add('bg-transparent');
          header?.classList.remove('bg-white', 'shadow-sm');
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  </script>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[#1c1c1c] text-white py-6">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo + contact info side by side -->
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <img src="https://cdn.sanity.io/images/vxczpihg/production/f95c2c1a3f77a64e7803bfcdc3138cc7a28937be-200x100.webp" alt="Scripture Alive" class="h-20 w-auto" />
        <div class="flex flex-col gap-2 text-sm text-white/80">
          <button onclick="window.location='mailto:jeremy@scripturealive.com'" class="hover:text-primary flex items-center gap-1.5 text-left cursor-pointer bg-transparent border-0 p-0 text-white/80">
            <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            Email Jeremy
          </button>
          <a href="tel:+13126000765" class="hover:text-primary flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            (312) 600-0765
          </a>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            South Bend, IN
          </span>
        </div>
      </div>
      <!-- Right: social icons -->
      <div class="flex items-center gap-4">
        <a href="https://facebook.com/ScriptureAliveOfficial" class="text-white hover:text-primary" aria-label="Facebook">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073C24 5.406 18.627 0 12 0S0 5.406 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047v-2.66c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.265h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/ScriptureAlive/" class="text-white hover:text-primary" aria-label="Instagram">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.youtube.com/channel/UC3GRn5EWEwxD9eu3kRvJ4lQ" class="text-white hover:text-primary" aria-label="YouTube">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>
    <div class="text-center text-white/40 text-xs mt-4">
      &copy; {new Date().getFullYear()} Scripture Alive. Powered by <a href="https://spiritmediapublishing.com" class="hover:text-white transition-colors">Spirit Media</a>.
    </div>
  </footer>

</body>
</html>
