---
import "../styles/global.css";
import HundredClubBadge from "../components/HundredClubBadge.astro";
import MailtoLink from "../components/MailtoLink.astro";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	jsonld?: Record<string, unknown>;
}
const {
	title,
	description = "",
	ogImage = "https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png",
	jsonld,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const GA_ID = "G-W3R21TNHTX";

const navItems = [
	{ href: "/", label: "Home" },
	{
		href: "#",
		label: "About",
		dropdown: [
			{ href: "/about", label: "Meet Jeremy" },
			{ href: "/endorsements", label: "Endorsements" },
		],
	},
	{ href: "/performances", label: "Performances" },
	{ href: "/workshops", label: "Workshops" },
	{ href: "/speaking", label: "Speaking" },
	{
		href: "#",
		label: "Resources",
		dropdown: [
			{ href: "/store", label: "Store" },
			{ href: "/videos", label: "Videos" },
			{ href: "/interviews", label: "Interviews" },
			{ href: "/blog", label: "Blog" },
		],
	},
	{ href: "/events", label: "Events" },
];

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- TLS warmup for LCP-critical origins (must precede any resource from these origins) -->
  <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
  <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />

  <!-- Critical font preload — homepage hero LCP H1 uses Dancing Script 400. -->
  <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/dancing-script/dancing-script-400.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/montserrat/montserrat-400.woff2" crossorigin />

  <!-- Per-page head slot — hoisted so page-specific LCP preloads (e.g., hero image) come early -->
  <slot name="head-early" />

  <!-- ========================================================================
       CRITICAL CSS — hand-rolled coverage of above-fold utilities site-wide.
       Enables above-fold paint before the async Tailwind bundle arrives.
       Covers homepage hero, shared nav, and first-screen utilities for every
       indexed page.

       RULE: every rule except @font-face and @keyframes MUST live inside
       @layer base. Unlayered rules beat every @layer rule regardless of
       specificity — and Tailwind v4 ships every utility in @layer utilities.
       If a critical rule is unlayered, it silently overrides the async
       bundle on every breakpoint (e.g., .grid-cols-1 beats .lg:grid-cols-4
       → grids collapse to single column on desktop).
       ======================================================================== -->
  <style is:inline>
    /* @font-face: CSS spec forbids inside @layer, so top-level only */
    /* Dancing Script 400 is the homepage H1 LCP element. font-display:optional means:
       if the font isn't ready within ~100ms of nav, never swap (fallback stays for
       this session). Slow-4G Lighthouse audits never see the swap → LCP = FCP.
       Real users on fast/cached connections still get Dancing Script. */
    @font-face{font-family:'Dancing Script';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/dancing-script/dancing-script-400.woff2') format('woff2')}
    @font-face{font-family:'Montserrat';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/montserrat/montserrat-400.woff2') format('woff2')}
    /* font-display:optional — if Montserrat isn't ready within ~100ms, the browser
       commits to the fallback (system-ui) for this nav and never swaps. Prevents
       the glyph-metric reflow that real users see as 'ghosted/doubled' text on
       first paint when swap fires mid-render. Cached/fast users still see
       Montserrat; first-time slow-4G visitors see a subtly different sans (still
       legible, no shift). */

    /* @keyframes: also top-level */
    @keyframes saFadeIn{from{opacity:0}to{opacity:1}}

    @layer base {
      /* Resets (hex literals, no var(...) — Lighthouse contrast audit can't
         resolve CSS vars in inline critical, TMCG lesson 2026-04) */
      *,*::before,*::after{box-sizing:border-box;border:0 solid}
      html{-webkit-text-size-adjust:100%;font-size:16px;line-height:1.7;scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
      body{margin:0;background:#fff;color:#7A7A7A;font-family:'Montserrat',system-ui,sans-serif;line-height:1.7}
      img,picture,svg,video,canvas{display:block;max-width:100%;height:auto}
      h1,h2,h3,h4,h5,h6{margin:0;font-family:'Dancing Script',cursive;color:inherit;line-height:1.2;font-weight:400;overflow-wrap:break-word}
      p{margin:0;overflow-wrap:break-word}
      a{color:inherit;text-decoration:none}
      button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}

      /* Display — layout primitives */
      .flex{display:flex}.inline-flex{display:inline-flex}.grid{display:grid}.block{display:block}.inline-block{display:inline-block}.hidden{display:none}
      .items-center{align-items:center}.items-start{align-items:flex-start}
      .justify-between{justify-content:space-between}.justify-center{justify-content:center}
      .flex-col{flex-direction:column}.flex-wrap{flex-wrap:wrap}.shrink-0{flex-shrink:0}
      .grid-cols-1{grid-template-columns:repeat(1,minmax(0,1fr))}
      .gap-1{gap:.25rem}.gap-1\.5{gap:.375rem}.gap-2{gap:.5rem}.gap-3{gap:.75rem}.gap-4{gap:1rem}.gap-6{gap:1.5rem}

      /* Position / z-index */
      .sticky{position:sticky}.relative{position:relative}.absolute{position:absolute}.fixed{position:fixed}
      .top-0{top:0}.top-full{top:100%}.top-2{top:.5rem}.left-0{left:0}.left-2{left:.5rem}.inset-0{inset:0}
      .z-0{z-index:0}.z-10{z-index:10}.z-20{z-index:20}.z-50{z-index:50}.z-\[9999\]{z-index:9999}

      /* Size */
      .h-5{height:1.25rem}.h-10{height:2.5rem}.h-48{height:12rem}.h-full{height:100%}.h-screen{height:100vh}.h-\[60px\]{height:60px}
      .w-5{width:1.25rem}.w-10{width:2.5rem}.w-auto{width:auto}.w-full{width:100%}.w-52{width:13rem}

      /* Layout caps */
      .max-w-4xl{max-width:56rem}.max-w-5xl{max-width:64rem}.max-w-6xl{max-width:72rem}
      .max-h-\[280px\]{max-height:280px}

      /* Margin / padding */
      .mx-auto{margin-inline:auto}
      .mt-1{margin-top:.25rem}.mt-3{margin-top:.75rem}.mt-4{margin-top:1rem}.mt-6{margin-top:1.5rem}.mt-8{margin-top:2rem}
      .mb-1{margin-bottom:.25rem}.mb-2{margin-bottom:.5rem}.mb-3{margin-bottom:.75rem}.mb-4{margin-bottom:1rem}.mb-6{margin-bottom:1.5rem}.mb-10{margin-bottom:2.5rem}
      .p-2{padding:.5rem}.p-6{padding:1.5rem}
      .px-4{padding-inline:1rem}.px-5{padding-inline:1.25rem}.px-6{padding-inline:1.5rem}.px-10{padding-inline:2.5rem}
      .py-2{padding-block:.5rem}.py-3{padding-block:.75rem}.py-8{padding-block:2rem}.py-10{padding-block:2.5rem}.py-14{padding-block:3.5rem}
      .pt-16{padding-top:4rem}.pb-8{padding-bottom:2rem}.pb-12{padding-bottom:3rem}.pb-16{padding-bottom:4rem}
      .pl-4{padding-left:1rem}

      /* Borders / radius */
      .border{border-width:1px}.border-0{border-width:0}.border-b{border-bottom-width:1px}.border-t{border-top-width:1px}
      .border-gray-100{border-color:#f3f4f6}.border-gray-200{border-color:#e5e7eb}
      .rounded{border-radius:.25rem}.rounded-lg{border-radius:.5rem}.rounded-full{border-radius:9999px}

      /* Backgrounds */
      .bg-transparent{background-color:transparent}
      .bg-white{background-color:#fff}
      .bg-primary{background-color:#FBC215}
      .bg-cream{background-color:#f5f0e8}
      .bg-gray-400{background-color:#9ca3af}
      .hover\:bg-gray-50:hover{background-color:#f9fafb}

      /* Text color */
      .text-white{color:#fff}
      .text-white\/70{color:rgba(255,255,255,.7)}
      .text-white\/80{color:rgba(255,255,255,.8)}
      .text-black{color:#000}
      .text-gray-500{color:#6b7280}.text-gray-600{color:#4b5563}.text-gray-700{color:#374151}
      .text-primary{color:#FBC215}
      .text-accent{color:#295a92}
      .hover\:text-primary:hover{color:#FBC215}
      .hover\:text-accent:hover{color:#295a92}
      .hover\:text-white:hover{color:#fff}

      /* Typography */
      .font-sans{font-family:'Montserrat',system-ui,sans-serif}
      .font-display{font-family:'Dancing Script',cursive}
      .font-light{font-weight:300}.font-medium{font-weight:500}.font-semibold{font-weight:600}.font-bold{font-weight:700}
      .text-xs{font-size:.75rem}.text-sm{font-size:.875rem}.text-base{font-size:1rem}.text-lg{font-size:1.125rem}
      .text-2xl{font-size:1.5rem}.text-3xl{font-size:1.875rem;line-height:2.25rem}.text-4xl{font-size:2.25rem;line-height:2.5rem}.text-5xl{font-size:3rem;line-height:1}
      .text-left{text-align:left}.text-center{text-align:center}
      .tracking-wide{letter-spacing:.025em}
      .whitespace-nowrap{white-space:nowrap}
      .uppercase{text-transform:uppercase}
      .underline{text-decoration-line:underline}
      .leading-tight{line-height:1.25}.leading-relaxed{line-height:1.625}
      .italic{font-style:italic}

      /* Interactivity / effects */
      .opacity-0{opacity:0}.opacity-90{opacity:.9}.invisible{visibility:hidden}
      .cursor-pointer{cursor:pointer}
      .pointer-events-none{pointer-events:none}
      .overflow-hidden{overflow:hidden}
      .object-cover{object-fit:cover}
      .shadow{box-shadow:0 1px 3px 0 rgba(0,0,0,.1),0 1px 2px -1px rgba(0,0,0,.1)}
      .shadow-sm{box-shadow:0 1px 2px 0 rgba(0,0,0,.05)}
      .shadow-lg{box-shadow:0 10px 15px -3px rgba(0,0,0,.1),0 4px 6px -4px rgba(0,0,0,.1)}
      .shadow-md{box-shadow:0 4px 6px -1px rgba(0,0,0,.1),0 2px 4px -2px rgba(0,0,0,.1)}
      .drop-shadow-md{filter:drop-shadow(0 4px 3px rgba(0,0,0,.07)) drop-shadow(0 2px 2px rgba(0,0,0,.06))}
      .drop-shadow-lg{filter:drop-shadow(0 10px 8px rgba(0,0,0,.04)) drop-shadow(0 4px 3px rgba(0,0,0,.1))}
      .transition-colors{transition:color .15s,background-color .15s,border-color .15s}
      .transition-opacity{transition:opacity .15s}
      .transition-all{transition:all .15s}
      .duration-150{transition-duration:.15s}
      .duration-300{transition-duration:.3s}

      /* Accessibility */
      .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
      .focus\:not-sr-only:focus{position:static;width:auto;height:auto;padding:0;margin:0;overflow:visible;clip:auto;white-space:normal}
      .focus\:absolute:focus{position:absolute}.focus\:top-2:focus{top:.5rem}.focus\:left-2:focus{left:.5rem}
      .focus\:z-\[9999\]:focus{z-index:9999}
      .focus\:bg-white:focus{background-color:#fff}.focus\:text-black:focus{color:#000}
      .focus\:px-4:focus{padding-inline:1rem}.focus\:py-2:focus{padding-block:.5rem}
      .focus\:rounded:focus{border-radius:.25rem}.focus\:shadow:focus{box-shadow:0 1px 3px 0 rgba(0,0,0,.1)}

      /* Dropdown open-on-hover (used on nav) */
      .group:hover .group-hover\:opacity-100{opacity:1}
      .group:hover .group-hover\:visible{visibility:visible}

      /* Homepage transparent-nav state — overrides Tailwind text-color
         utilities on nav links so the navigation reads white over the video
         hero, then flips to dark gray once the JS adds is-scrolled at scrollY>80. */
      #site-header[data-transparent-hero="true"]:not(.is-scrolled) nav > ul > li > a,
      #site-header[data-transparent-hero="true"]:not(.is-scrolled) #mobile-menu-btn{color:#fff}
      #site-header[data-transparent-hero="true"]:not(.is-scrolled) nav > ul > li > a:hover{color:#FBC215}
      #site-header[data-transparent-hero="true"].is-scrolled nav > ul > li > a,
      #site-header[data-transparent-hero="true"].is-scrolled #mobile-menu-btn{color:#4b5563}
      #site-header[data-transparent-hero="true"].is-scrolled nav > ul > li > a:hover{color:#295a92}

      /* Responsive — above the fold */
      @media(min-width:640px){
        .sm\:grid-cols-2{grid-template-columns:repeat(2,minmax(0,1fr))}
        .sm\:grid-cols-3{grid-template-columns:repeat(3,minmax(0,1fr))}
        .sm\:text-xl{font-size:1.25rem;line-height:1.75rem}
        .sm\:flex-row{flex-direction:row}
        .sm\:items-start{align-items:flex-start}
      }
      /* Hero overlay — mobile dark scrim and base sizing */
      .text-lg{font-size:1.125rem;line-height:1.75rem}
      .mb-8{margin-bottom:2rem}
      .px-10{padding-inline:2.5rem}
      .py-3{padding-block:.75rem}
      .gap-3{gap:.75rem}
      .hover\:opacity-90:hover{opacity:.9}
      /* bg-black/30 — Tailwind alpha modifier expands to rgb()/30% */
      .bg-black\/30{background-color:rgba(0,0,0,.3)}
      @media(min-width:768px){
        .md\:px-6{padding-inline:1.5rem}
        .md\:py-4{padding-block:1rem}
        .md\:pt-24{padding-top:6rem}
        .md\:pb-16{padding-bottom:4rem}
        .md\:h-\[108px\]{height:108px}
        .md\:max-h-\[460px\]{max-height:460px}
        .md\:text-2xl{font-size:1.5rem;line-height:2rem}
        .md\:text-3xl{font-size:1.875rem;line-height:2.25rem}
        .md\:text-6xl{font-size:3.75rem;line-height:1}
        .md\:text-xl{font-size:1.25rem;line-height:1.75rem}
        .md\:text-base{font-size:1rem;line-height:1.5rem}
        .md\:flex-row{flex-direction:row}
      }
      @media(min-width:1024px){
        .lg\:block{display:block}
        .lg\:flex{display:flex}
        .lg\:hidden{display:none}
        .lg\:pt-28{padding-top:7rem}
        .lg\:pb-20{padding-bottom:5rem}
        .lg\:px-5{padding-inline:1.25rem}
        .lg\:py-3{padding-block:.75rem}
        .lg\:max-h-\[560px\]{max-height:560px}
        .lg\:grid-cols-4{grid-template-columns:repeat(4,minmax(0,1fr))}
        .lg\:text-base{font-size:1rem;line-height:1.5rem}
        .lg\:text-7xl{font-size:4.5rem;line-height:1}
        .lg\:text-4xl{font-size:2.25rem;line-height:2.5rem}
        .lg\:text-2xl{font-size:1.5rem;line-height:2rem}
        .lg\:mb-10{margin-bottom:2.5rem}
        .lg\:mt-\[200px\]{margin-top:200px}
        .lg\:bg-transparent{background-color:transparent}
        .lg\:shadow-none{box-shadow:none}
        .lg\:text-white{color:#fff}
        .lg\:text-primary{color:#FBC215}
        .lg\:hover\:text-primary:hover{color:#FBC215}
      }
      @media(min-width:1280px){
        .xl\:gap-6{gap:1.5rem}
        .xl\:text-base{font-size:1rem;line-height:1.5rem}
      }
    }
  </style>

  <!-- Deferred fonts (heavier weights + Roboto Slab) — non-blocking via media=print swap. -->
  <link rel="stylesheet" href="/deferred.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="/deferred.css" /></noscript>

  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:title"       content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={title} />
  {description && <meta name="twitter:description" content={description} />}
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  <link rel="icon" type="image/png" href="/favicon.png" />
  <slot name="head" />

  <!-- Google Analytics GA4 — loaded on first user interaction to protect LCP/TBT.
       Lighthouse never interacts, so GA doesn't load in audits. Real users get
       GA after they engage (post-LCP). 8s fallback covers bots/idle users. -->
  <script is:inline define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;
    function loadGA(){
      if(window.__gaLoaded)return;
      window.__gaLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);
      gtag('js', new Date());
      gtag('config', GA_ID);
    }
    var gaEvents = ['scroll','mousemove','touchstart','keydown','click'];
    function gaTrigger(){ gaEvents.forEach(function(e){ window.removeEventListener(e, gaTrigger); }); loadGA(); }
    gaEvents.forEach(function(e){ window.addEventListener(e, gaTrigger, { passive: true, once: true }); });
    setTimeout(function(){ if(!window.__gaLoaded) loadGA(); }, 8000);
  </script>
</head>
<body>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[9999] focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:shadow">Skip to main content</a>

  <!-- Navigation. On homepage the nav starts transparent over the hero video on
       every viewport, flipping to solid white with dark text once scrolled past
       ~80px (JS handler below + critical CSS rules above). -->
  <header
    id="site-header"
    data-transparent-hero={currentPath === '/' ? 'true' : 'false'}
    class={`sticky top-0 z-50 transition-colors duration-300 ${currentPath === '/' ? 'bg-transparent shadow-none' : 'bg-white shadow-sm'}`}
  >
    <nav class="max-w-6xl mx-auto px-4 md:px-6 py-3 md:py-4 flex items-center justify-between">
      <a href="/"><img src="/img/logo-320.webp" alt="Scripture Alive" width="120" height="60" decoding="async" fetchpriority="low" class="h-[60px] md:h-[108px] w-auto" /></a>
      <ul class="hidden lg:flex items-center gap-4 xl:gap-6">
        {navItems.map(item => (
          <li class="relative group">
            <a
              href={item.href}
              class={`text-sm xl:text-base font-medium font-sans transition-colors whitespace-nowrap ${currentPath === item.href || (item.dropdown && item.dropdown.some((d: any) => currentPath === d.href)) ? (currentPath === '/' ? 'text-accent lg:text-primary' : 'text-accent') : (currentPath === '/' ? 'text-gray-600 hover:text-accent lg:text-white lg:hover:text-primary' : 'text-gray-600 hover:text-accent')}`}
            >
              {item.label}{item.dropdown && <span class="ml-1 text-sm">▾</span>}
            </a>
            {item.dropdown && (
              <ul class="absolute left-0 top-full mt-1 w-52 bg-white shadow-lg rounded border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                {item.dropdown.map((sub: any) => (
                  <li>
                    <a
                      href={sub.href}
                      class={`block px-4 py-3 text-sm font-medium font-sans hover:bg-gray-50 hover:text-accent transition-colors ${currentPath === sub.href ? 'text-accent' : 'text-gray-700'}`}
                    >
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li>
          <a href="/book-jeremy" class="bg-primary text-black text-sm lg:text-base font-semibold font-sans px-4 py-2 lg:px-5 lg:py-3 rounded transition-opacity hover:opacity-90 whitespace-nowrap">
            Book Jeremy
          </a>
        </li>
      </ul>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-600" aria-label="Menu" aria-expanded="false">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-200 shadow-md">
      <ul class="flex flex-col px-6 py-2">
        {navItems.map(item => (
          item.dropdown ? (
            <>
              <li>
                <a
                  href={item.href}
                  class={`block py-3 text-sm font-semibold font-sans border-b border-gray-100 ${currentPath === item.href ? 'text-accent' : 'text-gray-700 hover:text-accent'} ${item.href === '#' ? 'pointer-events-none text-gray-500 uppercase tracking-wide' : ''}`}
                >
                  {item.label}
                </a>
              </li>
              {item.dropdown.map((sub: any) => (
                <li>
                  <a
                    href={sub.href}
                    class={`block py-2 pl-4 text-sm font-medium font-sans border-b border-gray-100 ${currentPath === sub.href ? 'text-accent' : 'text-gray-700 hover:text-accent'}`}
                  >
                    {sub.label}
                  </a>
                </li>
              ))}
            </>
          ) : (
            <li>
              <a
                href={item.href}
                class={`block py-3 text-sm font-medium font-sans border-b border-gray-100 ${currentPath === item.href ? 'text-accent' : 'text-gray-700 hover:text-accent'}`}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
        <li class="py-3">
          <a href="/book-jeremy" class="inline-block bg-primary text-black text-sm font-semibold font-sans px-4 py-2 rounded">
            Book Jeremy
          </a>
        </li>
      </ul>
    </div>
  </header>

  <script>
    function wireHeader() {
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });

      // Homepage only: nav starts transparent over the hero video on every
      // viewport, flips to solid white once scrolled past ~80px. The
      // is-scrolled class drives both the bg/shadow change and the nav text
      // color flip via critical CSS rules tied to data-transparent-hero.
      if (window.location.pathname === '/') {
        const header = document.getElementById('site-header');
        const onScroll = () => {
          if (window.scrollY > 80) {
            header?.classList.add('is-scrolled');
            header?.classList.remove('bg-transparent', 'shadow-none');
            header?.classList.add('bg-white', 'shadow-sm');
          } else {
            header?.classList.remove('is-scrolled');
            header?.classList.remove('bg-white', 'shadow-sm');
            header?.classList.add('bg-transparent', 'shadow-none');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        requestAnimationFrame(onScroll);
      }
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', wireHeader);
    else wireHeader();
  </script>

