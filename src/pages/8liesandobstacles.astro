---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="8 Lies and Obstacles About Memorizing Scripture | Scripture Alive"
  description="Download the PDF article exposing the 8 most common lies and obstacles that keep people from memorizing God's Word."
>
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-6">8 Lies and Obstacles About Memorizing Scripture</h1>
      <p class="text-gray-700 text-lg mb-8">Download the PDF article exposing the 8 most common lies and obstacles that keep people from memorizing God's Word.</p>
      <img
        src="https://cdn.sanity.io/images/vxczpihg/production/b1b9146f5720875ece6346aaec97a980ca191f14-768x768.png"
        alt="8 Lies and Obstacles About Memorizing Scripture"
        class="mx-auto rounded shadow-md mb-8 max-w-xs w-full"
        loading="lazy"
      />
      <a
        href="https://assets.spiritmediapublishing.com/scripture-alive/8-lies-about-memorizing-scripture.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white font-bold px-8 py-3 rounded text-lg hover:bg-accent/90 transition-colors"
      >
        Download Free PDF
      </a>
    </div>
  </section>
</Layout>
