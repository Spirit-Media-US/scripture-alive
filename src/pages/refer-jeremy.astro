---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found - Scripture Alive"
  description=""
  ogImage="https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png"
>
  <main id="content" class="site-main min-h-[60vh] flex flex-col items-start justify-center py-20 px-8">
    <div class="max-w-2xl w-full text-left">
      <h1 class="text-4xl font-bold mb-4" style="color: #333; font-family: sans-serif;">
        The page can't be found.
      </h1>
      <div class="text-base text-gray-500 mb-4">
        <p>It looks like nothing was found at this location.</p>
      </div>
    </div>
  </main>
</Layout>