---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found - Scripture Alive"
  description=""
  ogImage="https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png"
>
  <main id="content" class="site-main min-h-[60vh] flex flex-col items-center justify-center py-20 px-4">
    <div class="max-w-2xl w-full text-center">
      <h1 class="text-4xl font-bold mb-6" style="color: #c9a84c; font-family: Lora, serif;">
        The page can't be found.
      </h1>
      <div class="text-lg text-gray-600 mb-8">
        <p>It looks like nothing was found at this location.</p>
      </div>
      <a
        href="/"
        class="inline-block font-semibold px-8 py-3 rounded transition-colors duration-200"
        style="background-color: #c9a84c; color: white; font-family: Lora, serif;"
      >
        Return Home
      </a>
    </div>
  </main>
</Layout>