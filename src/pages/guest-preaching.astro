---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found - Scripture Alive"
  description=""
  ogImage="https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png"
>
  <main class="min-h-screen flex flex-col items-start justify-start py-16 px-8">
    <div class="max-w-2xl w-full">
      <h1 class="text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Montserrat', sans-serif;">
        The page can't be found.
      </h1>
      <p class="text-base text-gray-500">
        It looks like nothing was found at this location.
      </p>
    </div>
  </main>
</Layout>