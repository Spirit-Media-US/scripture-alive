---
import Layout from "../../layouts/Layout.astro";

const items = [
	{
		title: "One-on-One Coaching",
		description:
			"Personalized coaching sessions tailored to your Scripture memorization goals. Whether you're memorizing your first chapter or preparing to perform an entire book, Jeremy provides expert guidance every step of the way. [Placeholder — Jeremy to provide final content]",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/38324834d0ffccdfaf850977f387480d77821cdb-1024x682.webp",
	},
	{
		title: "Group Coaching Sessions",
		description:
			"Small group coaching for teams, families, or ministry groups working through Scripture memorization together. Jeremy leads interactive sessions that build accountability, confidence, and lasting habits. [Placeholder — Jeremy to provide final content]",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/942aa7d8126971cf426041b33e23c0a016d850cc-1024x682.webp",
	},
	{
		title: "Custom Coaching Program",
		description:
			"A tailored coaching program designed around your specific needs — whether it's Scripture memorization, public reading, or dramatic performance preparation. Jeremy works with you to create a plan that fits your goals and timeline. [Placeholder — Jeremy to provide final content]",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/764d21372720ef6071ce1eb266d0cd271e296b48-1024x682.webp",
	},
];
---

<Layout
  title="Scripture Coaching | Scripture Alive"
  description="Personalized coaching in Scripture memorization and presentation — for individuals, students, and performers."
>

  <!-- Back Button -->
  <div class="max-w-5xl mx-auto px-4 pt-6">
    <a href="/speaking" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-700 hover:text-accent transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Speaking
    </a>
  </div>

  <!-- Hero -->
  <section class="py-10 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">
        <a href="/speaking" class="hover:underline">Speaking</a> / Scripture Coaching
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-accent font-display mb-4">
        Scripture Coaching
      </h1>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed">
        Personalized coaching in Scripture memorization and presentation — for individuals, students, and performers.
      </p>
    </div>
  </section>

  <!-- Accordion Items -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-5xl mx-auto flex flex-col gap-4">
      {items.map((item) => (
        <details class="bg-white rounded-lg shadow-sm overflow-hidden group">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none">
            <h2 class="text-lg font-bold text-gray-800 font-serif">{item.title}</h2>
            <span class="text-accent font-bold text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4">
            <img
              src={item.image}
              alt={item.title}
              loading="lazy"
              class="w-full rounded"
            />
            <p class="text-gray-600 leading-relaxed text-sm">{item.description}</p>
            <div>
              <a
                href="/book-jeremy"
                class="inline-block bg-primary text-gray-900 font-bold px-6 py-3 rounded hover:opacity-90 transition-opacity text-sm"
              >
                Book This
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-primary font-serif mb-4">
        Ready to take your Scripture skills to the next level?
      </h2>
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-gray-900 font-bold px-8 py-3 rounded hover:opacity-90 transition-opacity"
      >
        Book a Speaking Engagement
      </a>
    </div>
  </section>

</Layout>
