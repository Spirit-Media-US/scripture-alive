---
import Layout from "../../layouts/Layout.astro";

const items = [
	{
		title: "Elijah: God Provides in Tough Times",
		description:
			"Elijah's journey is filled with incredible stories of obedience, faith, and provision in the midst of a drought, a depression, and a departure as he is tested to trust in the word of the Lord. Any chapter from 1 Kings 17–2 Kings 2 can be chosen for a sermon, or all can be chosen for a retreat or camp week.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-elijah.webp",
	},
	{
		title: "Daniel: Being Godly in an Ungodly World",
		description:
			"From a young teenager to an old man, Daniel sets us an example worthy to be emulated in his speech, in his conduct, in his love, in his faith, and in his purity, all while being forced to live in a culture of the ungodly. Any chapter from 1–6 can be chosen for a sermon, or all can be chosen for a retreat or camp week.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-daniel.webp",
	},
	{
		title: "Paul: Steadfastness & Stability in an Anxious World",
		description:
			"No matter the circumstance, whether it be imprisonment, being stoned, or being shipwrecked, Paul was a constant non-anxious presence wherever he went and a steadfast proclaimer of the Gospel to all he came in contact with, which gives us a blueprint for how we ought to act in our own world today. Chapters from Acts 9–28 can be chosen for a sermon, or the whole journey of Paul's life can be chosen for a retreat.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-paul.webp",
	},
	{
		title: "John's Gospel: That You May Believe",
		description:
			"In this Gospel account, John recounts many of the miracles and teachings of Jesus in an effort to show His divinity that we may believe He truly is the Christ and that we might have life in His name. This is a five-part series that works well with retreats, but can also be modified as a sermon for a chapter or passage from John's Gospel.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-john-gospel.jpg",
	},
	{
		title: "1 Peter: Suffering for Christ",
		description:
			"Peter makes it clear that we should not be surprised at the fiery trial when it comes upon us to test us as though something strange was happening to us, but rather we are to rejoice insofar as we share Christ's sufferings. Christ set the standard for suffering well as a believer, so it's vital for us to learn how to suffer well as sojourners and exiles in this world. Can be any or all five chapters for a retreat or sermon.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-peter.png",
	},
	{
		title: "Custom Programs/Sermons",
		description:
			"Doing a topical sermon series or an in-depth study of a narrative book like Genesis or Acts and want to stay on track? You can also request Jeremy to study and memorize a passage, chapter, or verses on a specific topic for his performance and preaching combination.",
		image:
			"https://assets.spiritmediapublishing.com/scripture-alive/speaking-custom-programs.webp",
	},
];
---

<Layout
  title="Church & Event Speaking | Scripture Alive"
  description="Biblical messages for churches, retreats, conferences, camps, and schools — pairing live Scripture performance with powerful teaching."
>

  <!-- Back Button -->
  <div class="max-w-5xl mx-auto px-4 pt-6">
    <a href="/speaking" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-700 hover:text-accent transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Speaking
    </a>
  </div>

  <!-- Hero -->
  <section class="py-10 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">
        <a href="/speaking" class="hover:underline">Speaking</a> / Church & Event Speaking
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-accent font-display mb-4">
        Church & Event Speaking
      </h1>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed">
        Biblical messages for churches, retreats, conferences, camps, and schools — pairing live Scripture performance with powerful teaching.
      </p>
    </div>
  </section>

  <!-- Accordion Items -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-5xl mx-auto flex flex-col gap-4">
      {items.map((item) => (
        <details class="bg-white rounded-lg shadow-sm overflow-hidden group">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none">
            <h2 class="text-lg font-bold text-gray-800 font-serif">{item.title}</h2>
            <span class="text-accent font-bold text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4">
            <img
              src={item.image}
              alt={item.title}
              loading="lazy"
              class="w-full rounded"
            />
            <p class="text-gray-600 leading-relaxed text-sm">{item.description}</p>
            <div>
              <a
                href="/book-jeremy"
                class="inline-block bg-primary text-gray-900 font-bold px-6 py-3 rounded hover:opacity-90 transition-opacity text-sm"
              >
                Book This
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-primary font-serif mb-4">
        Ready to bring God's Word to your event?
      </h2>
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-gray-900 font-bold px-8 py-3 rounded hover:opacity-90 transition-opacity"
      >
        Book a Speaking Engagement
      </a>
    </div>
  </section>

</Layout>
