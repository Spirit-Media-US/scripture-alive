---
import Layout from "../../layouts/Layout.astro";

const workshops = [
	{
		title: "Praying the Word",
		description:
			"How to use Scripture memory for greater depth and confidence in your prayer life. This workshop teaches participants to weave memorized passages into their prayers — enriching conversations with God through His own words.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/2f794fd31d202babdc31b4c7caea239a0cd6d45e-1024x682.png",
	},
	{
		title: "Witnessing with the Word",
		description:
			"How to use Scripture memory to share the Gospel with others. Learn to draw on memorized verses naturally in evangelistic conversations — equipping you to share your faith with clarity and confidence.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/5b5f24412ee24413a1313218d7f147eee363b941-1024x682.webp",
	},
	{
		title: "Holding Fast to God's Word",
		description:
			"How Scripture memory can help you in seasons of trials and temptations. When the storms of life hit, having God's Word stored in your heart becomes an anchor. This workshop shows you how to lean on memorized Scripture in your hardest moments.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/80d50746c21de9f688034d67ed88bae2efe55536-1024x682.png",
	},
];
---

<Layout
  title="Discipleship Track Workshops | Scripture Alive"
  description="Discipleship-focused workshops — praying the Word, witnessing with Scripture, and holding fast in trials."
>

  <!-- Hero -->
  <section class="py-10 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">
        <a href="/workshops" class="hover:underline">Workshops</a> / Discipleship Track
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-accent font-display mb-4">
        Discipleship Track
      </h1>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed">
        Deeper workshops that apply Scripture memory to prayer, evangelism, and perseverance through life's toughest seasons.
      </p>
    </div>
  </section>

  <!-- Accordion Items -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-5xl mx-auto flex flex-col gap-4">
      {workshops.map((workshop) => (
        <details class="bg-white rounded-lg shadow-sm overflow-hidden group">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none">
            <h2 class="text-lg font-bold text-gray-800 font-serif">{workshop.title}</h2>
            <span class="text-accent font-bold text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4">
            <img
              src={workshop.image}
              alt={`${workshop.title} Workshop`}
              loading="lazy"
              class="w-full rounded"
            />
            <p class="text-gray-600 leading-relaxed text-sm">{workshop.description}</p>
            <div>
              <a
                href="/book-jeremy"
                class="inline-block bg-primary text-gray-900 font-bold px-6 py-3 rounded hover:opacity-90 transition-opacity text-sm"
              >
                Book This Workshop
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-bold text-primary font-serif mb-4">
        Ready to take your group deeper into God's Word?
      </h2>
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-gray-900 font-bold px-8 py-3 rounded hover:opacity-90 transition-opacity"
      >
        Book a Workshop
      </a>
    </div>
  </section>

</Layout>
