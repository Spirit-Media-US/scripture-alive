---
import Layout from "../layouts/Layout.astro";
import { getResources } from "../utils/sanity";

// R2 fallback images by slug until uploaded to Sanity Studio
const fallbackImages: Record<string, string> = {
	powersystem:
		"https://cdn.sanity.io/images/vxczpihg/production/b64aaa1abc071deb93aac9181dbbe2a0994736bc-768x512.png",
	worksheet:
		"https://cdn.sanity.io/images/vxczpihg/production/6be4c582604d2aac4a19c30393effb34cefde179-768x512.png",
	"8reasonswhy":
		"https://cdn.sanity.io/images/vxczpihg/production/79342581e717546843031fd779561216c80f71f6-768x768.png",
	"8liesandobstacles":
		"https://cdn.sanity.io/images/vxczpihg/production/b1b9146f5720875ece6346aaec97a980ca191f14-768x768.png",
	creative:
		"https://cdn.sanity.io/images/vxczpihg/production/b51eac64bfe484a1630a117d5de6440bdfc3b182-1080x1080.png",
	topicalverses:
		"https://cdn.sanity.io/images/vxczpihg/production/b64aaa1abc071deb93aac9181dbbe2a0994736bc-768x512.png",
	scripturealiveinfosheet:
		"https://cdn.sanity.io/images/vxczpihg/production/ff662f2e455548bebc940040a43656e153954c86-286x397.webp",
};

const resources = await getResources();
---

<Layout
  title="Resources | Scripture Alive"
  description="Bible study and memory resources to help you take your next steps in your walk with Christ."
  jsonld={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Resources | Scripture Alive",
    "url": "https://scripturealive.com/resources",
    "description": "Bible study and memory resources to help you take your next steps in your walk with Christ.",
    "about": {
      "@type": "Organization",
      "name": "Scripture Alive",
      "url": "https://scripturealive.com"
    }
  }}
>

  <!-- Page Heading -->
  <section class="py-10 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-4">
        Scripture Alive Resources
      </h1>
      <p class="text-gray-700 text-lg max-w-2xl mx-auto">
        Bible study and memory resources to help you take your next steps in your walk with Christ.
      </p>
    </div>
  </section>

  <!-- Resources Grid from Sanity -->
  <section class="pb-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {resources.map((r: any) => {
        const imgSrc = fallbackImages[r.slug] ?? fallbackImages['powersystem'];
        return (
          <div class="border border-gray-200 rounded p-6 bg-white shadow-sm flex flex-col gap-4">
            <img
              src={imgSrc}
              alt={r.title}
              loading="lazy"
              class="w-full rounded object-cover max-h-48"
            />
            <h2 class="text-lg font-bold text-primary font-serif">{r.title}</h2>
            <p class="text-gray-700 leading-relaxed flex-1">{r.description}</p>
            <div class="flex gap-3 flex-wrap">
              <a
                href={`/${r.slug}`}
                class="inline-block bg-accent text-white font-semibold px-4 py-2 rounded text-sm hover:bg-accent/90 transition-colors"
              >
                View Page
              </a>
              <a
                href={r.pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block bg-accent text-white font-semibold px-4 py-2 rounded text-sm hover:bg-accent/90 transition-colors"
              >
                Download PDF
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

</Layout>
