---
import Layout from '../layouts/Layout.astro';
import { getResources } from '../utils/sanity';

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";

// R2 fallback images by slug until uploaded to Sanity Studio
const fallbackImages: Record<string, string> = {
  powersystem: `${BASE}/SA-POWER-System-Graphic-768x512.png`,
  worksheet: `${BASE}/SA-Personal-Memory-Plan-768x512.png`,
  '8reasonswhy': `${BASE}/8-Reasons-Why-To-Memorize-Scripture-List-Sq-768x768.png`,
  '8liesandobstacles': `${BASE}/8-Lies-We-Believe-About-Memorizing-Scripture-List-Sq-768x768.png`,
  creative: `${BASE}/Creative-Ways-to-Memorize-Scripture-List-Sq.png`,
  topicalverses: `${BASE}/SA-POWER-System-Graphic-768x512.png`,
  scripturealiveinfosheet: `${BASE}/d0b2aceb029909de1f63dd05cb63c4af_1200_80-rdodoupx7nidwtzgvi31qpkih69etmmxm500ypsw76.webp`,
};

const resources = await getResources();
---

<Layout
  title="Resources | Scripture Alive"
  description="Bible study and memory resources to help you take your next steps in your walk with Christ."
>

  <!-- Page Heading -->
  <section class="py-10 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-4">
        Scripture Alive Resources
      </h1>
      <p class="text-gray-700 text-lg max-w-2xl mx-auto">
        Bible study and memory resources to help you take your next steps in your walk with Christ.
      </p>
    </div>
  </section>

  <!-- Resources Grid from Sanity -->
  <section class="pb-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {resources.map((r: any) => {
        const imgSrc = fallbackImages[r.slug] ?? fallbackImages['powersystem'];
        return (
          <div class="border border-gray-200 rounded p-6 bg-white shadow-sm flex flex-col gap-4">
            <img
              src={imgSrc}
              alt={r.title}
              loading="lazy"
              class="w-full rounded object-cover max-h-48"
            />
            <h2 class="text-lg font-bold text-primary font-serif">{r.title}</h2>
            <p class="text-gray-700 leading-relaxed flex-1">{r.description}</p>
            <div class="flex gap-3 flex-wrap">
              <a
                href={`/${r.slug}`}
                class="inline-block bg-accent text-white font-semibold px-4 py-2 rounded text-sm hover:bg-accent/90 transition-colors"
              >
                View Page
              </a>
              <a
                href={r.pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block bg-accent text-white font-semibold px-4 py-2 rounded text-sm hover:bg-accent/90 transition-colors"
              >
                Download PDF
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

</Layout>
