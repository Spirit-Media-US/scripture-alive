---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="The POWER System for Scripture Memory | Scripture Alive"
  description="Download the official two-page POWER System memorization process — effective, enjoyable, and faith-igniting."
>
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-6">The POWER System for Scripture Memory</h1>
      <p class="text-gray-700 text-lg mb-8">Download the official two-page POWER System memorization process — effective, enjoyable, and faith-igniting.</p>
      <img
        src="https://assets.spiritmediapublishing.com/scripture-alive/SA-POWER-System-Graphic-768x512.png"
        alt="The POWER System for Scripture Memory"
        class="mx-auto rounded shadow-md mb-8 max-w-xs w-full"
        loading="lazy"
      />
      <a
        href="https://assets.spiritmediapublishing.com/scripture-alive/POWER-System-for-Scripture-Memory.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white font-bold px-8 py-3 rounded text-lg hover:bg-accent/90 transition-colors"
      >
        Download Free PDF
      </a>
    </div>
  </section>
</Layout>
