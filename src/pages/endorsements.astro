---
import Layout from "../layouts/Layout.astro";
import { getTestimonials } from "../utils/sanity";

const testimonials = await getTestimonials();
---

<Layout
  title="Testimonials & Reviews | Scripture Alive"
  description="Hear what others say about Scripture Alive's impact for the Kingdom."
  ogImage="https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png"
  jsonld={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Testimonials & Reviews | Scripture Alive",
    "url": "https://scripturealive.com/endorsements",
    "description": "Hear what others say about Scripture Alive's impact for the Kingdom.",
    "about": {
      "@type": "Organization",
      "name": "Scripture Alive",
      "url": "https://scripturealive.com"
    }
  }}
>

  <section class="pt-16 pb-4 px-4 text-center bg-white">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-accent tracking-wide mb-10">
        Endorsements
      </h1>
    </div>
  </section>

  <section class="pb-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">

      {testimonials.map((t: any) => (
        <article class="text-center mb-14">
          <p class="text-gray-800 leading-relaxed mb-4 mx-auto">
            "{t.quote}"
          </p>
          <p class="font-semibold text-accent">{t.authorName}{t.authorTitle ? `, ${t.authorTitle}` : ''}</p>
          <p class="text-sm text-primary mt-1">{t.authorOrganization}</p>
        </article>
      ))}

    </div>
  </section>

</Layout>
