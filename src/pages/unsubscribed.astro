---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Unsubscribed | Scripture Alive"
  description="You have been successfully unsubscribed from Scripture Alive emails."
>
  <section class="py-20 px-4 text-center">
    <div class="max-w-xl mx-auto">
      <h1 class="text-3xl font-bold text-primary font-serif mb-4">Thank You!</h1>
      <p class="text-gray-700 text-lg">You have been successfully unsubscribed from our emails.</p>
      <a href="/" class="inline-block mt-8 bg-accent text-white font-semibold px-6 py-3 rounded hover:bg-accent/90 transition-colors">
        Return Home
      </a>
    </div>
  </section>
</Layout>
