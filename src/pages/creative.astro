---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Creative Ways to Memorize Scripture | Scripture Alive"
  description="Download the PDF with creative techniques and methods to help you memorize Scripture more effectively and enjoyably."
>
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-6">Creative Ways to Memorize Scripture</h1>
      <p class="text-gray-700 text-lg mb-8">Download the PDF with creative techniques and methods to help you memorize Scripture more effectively and enjoyably.</p>
      <img
        src="https://scripturealive.com/wp-content/uploads/2025/05/Creative-Ways-to-Memorize-Scripture-List-Sq.png"
        alt="Creative Ways to Memorize Scripture"
        class="mx-auto rounded shadow-md mb-8 max-w-xs w-full"
        loading="lazy"
      />
      <!-- TODO: Move PDF to R2 before launch if currently on WordPress -->
      <a
        href="https://storage.googleapis.com/msgsndr/s6tfZuCYRjEKf1S3JnqU/media/63cadddf841bfb23af50a449.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white font-bold px-8 py-3 rounded text-lg hover:bg-accent/90 transition-colors"
      >
        Download Free PDF
      </a>
    </div>
  </section>
</Layout>
