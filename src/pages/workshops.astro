---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Master Bible Memorization | Workshop Guide"
  description="Learn effective techniques & strategies to memorize Scripture at our specialized workshops."
  ogImage="https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80-1024x768.webp"
  type="general"
>

  <!-- Hero / Intro Section -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-accent font-serif mb-6">
        Interactive Bible Memory Workshops
      </h1>
      <p class="text-gray-700 leading-relaxed max-w-3xl mx-auto">
        Hands-on, topic-based sessions that equip people to memorize Scripture and live it out
        — with practical tools, group engagement, and biblical depth.
      </p>
    </div>
  </section>

  <!-- Three Workshop Topics Section -->
  <section class="py-6 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1: Reasons Why -->
        <div class="flex flex-col items-center text-center">
          <h2 class="text-2xl font-bold text-accent font-serif mb-4">Reasons Why</h2>
          <div class="w-full overflow-hidden rounded-lg border border-gray-200">
            <img
              src="https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80-1024x768.webp"
              alt="Reasons Why workshop"
              fetchpriority="high"
              decoding="async"
              width="800"
              height="600"
              srcset="
                https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80-300x225.webp 300w,
                https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80-768x576.webp 768w,
                https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80-1024x768.webp 1024w,
                https://assets.spiritmediapublishing.com/scripture-alive/6865005301c79a6751a57ebf4f16d840_1200_80.webp 1200w
              "
              sizes="(max-width: 800px) 100vw, 800px"
              class="w-full h-auto object-cover"
            />
          </div>
        </div>

        <!-- Card 2: Lies We Believe -->
        <div class="flex flex-col items-center text-center">
          <h2 class="text-2xl font-bold text-accent font-serif mb-4">Lies We Believe</h2>
          <div class="w-full overflow-hidden rounded-lg border border-gray-200">
            <img
              src="https://assets.spiritmediapublishing.com/scripture-alive/a5d055ad60dd66ac994d8b300751abc0_1200_80.webp"
              alt="Lies We Believe workshop"
              decoding="async"
              width="500"
              height="500"
              srcset="
                https://assets.spiritmediapublishing.com/scripture-alive/a5d055ad60dd66ac994d8b300751abc0_1200_80-150x150.webp 150w,
                https://assets.spiritmediapublishing.com/scripture-alive/a5d055ad60dd66ac994d8b300751abc0_1200_80-300x300.webp 300w,
                https://assets.spiritmediapublishing.com/scripture-alive/a5d055ad60dd66ac994d8b300751abc0_1200_80.webp 500w
              "
              sizes="(max-width: 500px) 100vw, 500px"
              class="w-full h-auto object-cover"
            />
          </div>
        </div>

        <!-- Card 3: POWER System -->
        <div class="flex flex-col items-center text-center">
          <h2 class="text-2xl font-bold text-accent font-serif mb-4">POWER System</h2>
          <div class="w-full overflow-hidden rounded-lg border border-gray-200">
            <img
              src="https://assets.spiritmediapublishing.com/scripture-alive/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-1024x759.webp"
              alt="POWER System workshop"
              decoding="async"
              width="800"
              height="593"
              srcset="
                https://assets.spiritmediapublishing.com/scripture-alive/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-300x223.webp 300w,
                https://assets.spiritmediapublishing.com/scripture-alive/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-768x570.webp 768w,
                https://assets.spiritmediapublishing.com/scripture-alive/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-1024x759.webp 1024w,
                https://assets.spiritmediapublishing.com/scripture-alive/672f0ecbb7fdae63f0f38d8a68af1122_1200_80.webp 1200w
              "
              sizes="(max-width: 800px) 100vw, 800px"
              class="w-full h-auto object-cover"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Testimonial + Description Section -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

        <!-- Testimonial -->
        <div class="border border-gray-200 rounded-lg p-8 flex flex-col gap-4">
          <p class="text-gray-700 leading-relaxed text-center italic">
            "Jeremy's workshop far exceeded my expectations! Extremely resourceful, immediately effective, and filled with fun and laughter. My 14 year-old son came away inspired to memorize God's Word for the transformation of his heart!"
          </p>
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-800 font-serif">Ty Spenst, Senior Pastor</h3>
            <p class="text-gray-600">Trinity EFC, Plainview MN</p>
          </div>
        </div>

        <!-- Description + Button -->
        <div class="flex flex-col justify-start gap-6">
          <p class="text-gray-700 leading-relaxed">
            Jeremy is passionate about inspiring and empowering people to store up God's Word in their hearts and to live it out. In this interactive and engaging workshop (45, 60, or 90 minutes based on your event/needs), Jeremy will help you to <strong>Discover Your Why,</strong> to <strong>Overcome Common Obstacles</strong>, and show you his proven, practical five-step <strong>POWER System</strong> that anyone can use to more effectively memorize Scripture. Contact Jeremy for info on how you can book him for your church or ministry.
          </p>
          <div>
            <a
              href="/contact"
              class="inline-block bg-accent text-white font-semibold font-serif text-base px-8 py-4 rounded hover:opacity-90 transition-opacity duration-200"
            >
              Contact Jeremy
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>