---
import Layout from "../layouts/Layout.astro";
import { getFeaturedTestimonials, getSiteSettings } from "../utils/sanity";

const featuredTestimonials = await getFeaturedTestimonials();
const settings = await getSiteSettings();
const totalSlides = featuredTestimonials.length;

// Apply Sanity CDN transforms. Service tiles display at ~320×192 (h-48 in a
// 3-col grid on lg+, max-w-5xl) so DPR 2 fetches should be 640×384 — matching
// the rendered image attrs.
const tileTransform = (url: string | undefined, fallback: string) => {
	const base = url || fallback;
	if (!base.includes("cdn.sanity.io")) return base;
	const sep = base.includes("?") ? "&" : "?";
	return `${base}${sep}w=640&h=384&fit=crop&fm=webp&q=75`;
};
const performancesImg = tileTransform(
	settings?.homePerformancesImage,
	"https://cdn.sanity.io/images/vxczpihg/production/77e01b90ecf67d8a98bd7b81065106b062648bf3-354x177.webp",
);
const workshopsImg = tileTransform(
	settings?.homeWorkshopsImage,
	"https://cdn.sanity.io/images/vxczpihg/production/adab64545b5f89913fecdfea364d41c884f063cc-354x177.webp",
);
const speakingImg = tileTransform(
	settings?.homeSpeakingImage,
	"https://cdn.sanity.io/images/vxczpihg/production/8e31433446554b2eb54ea4a475dec26aa0af6dcd-354x177.webp",
);
---

<Layout
  title="Performances | Workshops | Speaking | Scripture Alive"
  description="Scripture Alive, a ministry that exists to empower the Church to experience, engage, and embody God's Word."
  ogImage="https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png"
  jsonld={{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Scripture Alive",
    "url": "https://scripturealive.com",
    "logo": "https://cdn.sanity.io/images/vxczpihg/production/f95c2c1a3f77a64e7803bfcdc3138cc7a28937be-200x100.webp",
    "description": "Scripture Alive is a ministry that engages people with the Word of Truth through dramatic performances, Bible memorization workshops, and guest speaking.",
    "sameAs": ["https://scripturealive.com"],
    "founder": {
      "@type": "Person",
      "name": "Jeremy Kluth"
    }
  }}
>

  <Fragment slot="head">
    <!-- Pull the hero up under the transparent sticky nav so the video
         shows through the (otherwise transparent) header at scroll=0.
         Inline @media so it applies on first paint — a Tailwind
         lg:-mt-[140px] would land in the deferred external stylesheet and
         the section would paint at top:0 then jump up (CLS spike). Mobile
         nav is ~84px tall, desktop nav is ~140px tall. -->
    <style>
      #hero-section{margin-top:-84px;padding-top:84px}
      @media (min-width: 1024px){#hero-section{margin-top:-140px;padding-top:140px}}
    </style>
  </Fragment>

  <!-- HERO. Full-bleed video background with text + CTA overlaid on the left
       half. Jeremy is composed right-of-center in the source video, so the
       left side of the frame is mostly black — natural contrast for the
       overlay text, no dark scrim needed. -->
  <style is:global>
    /* Hero layout — stacked on mobile (video on top, text below),
       overlay on desktop (video full-bleed bg, text on top). */
    #hero-section{position:relative;background-color:#fff;}
    #hero-section .hero-video-wrap{position:relative;width:100%;aspect-ratio:16/9;overflow:hidden;background-color:#1c1917;}
    #hero-section .hero-video-wrap > video{width:100%;height:100%;object-fit:cover;}
    #hero-section .hero-mobile-h1{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1rem;text-align:center;color:#fff;z-index:5;pointer-events:none;}
    #hero-section .hero-text-wrap{display:flex;flex-direction:column;align-items:center;text-align:center;color:#1f2937;padding:2.5rem 1.5rem 3rem;}
    #hero-section .hero-content{max-width:36rem;width:100%;}
    @media (min-width:1024px){
      #hero-section{background-color:#1c1917;min-height:100vh;overflow:hidden;}
      #hero-section .hero-video-wrap{position:absolute;inset:0;aspect-ratio:auto;width:100%;height:100%;z-index:0;}
      #hero-section .hero-mobile-h1{display:none;}
      #hero-section .hero-text-wrap{position:relative;z-index:10;max-width:80rem;margin-left:auto;margin-right:auto;min-height:100vh;justify-content:flex-start;align-items:flex-start;text-align:left;padding:3rem 4rem 4rem 4rem;color:#fff;}
      #hero-section .hero-content{max-width:42rem;}
    }
  </style>
  <section id="hero-section" class="relative bg-stone-900">
    <!-- Video: contained 16:9 on mobile (top), full-bleed on desktop.
         Single 1080p source for both viewports — sharp on high-DPR phones. -->
    <div class="hero-video-wrap">
      <video
        id="hero-video"
        muted playsinline loop preload="none" aria-hidden="true"
        data-src="https://assets.spiritmediapublishing.com/scripture-alive/sa-opening-no-music-v2.mp4"
      ></video>
      <!-- Mobile-only headline overlay on the video -->
      <div class="hero-mobile-h1 lg:hidden">
        <h1 class="leading-tight drop-shadow-lg">
          <span class="block font-display font-light text-5xl sm:text-6xl">Making Scripture</span>
          <span class="block font-bold text-primary text-5xl sm:text-6xl" style="font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif">Unforgettable</span>
        </h1>
      </div>
    </div>
    <script is:inline>
      (function () {
        // 10MB video — desktop only. On mobile (< 1024px) the video sits in a
        // 412×232 box at top of hero; loading 10MB on slow-4G blew PSI mobile
        // FCP/LCP into bimodal 80/93 territory (2026-05-17). Mobile hero is
        // already visually complete with the static dark background + h1 overlay.
        if (!window.matchMedia('(min-width: 1024px)').matches) return;
        var loadVideo = function () {
          var v = document.getElementById('hero-video');
          if (!v || v.dataset.loaded) return;
          v.dataset.loaded = '1';
          var s = document.createElement('source');
          s.src = v.dataset.src;
          s.type = 'video/mp4';
          v.appendChild(s);
          v.load();
          var p = v.play();
          if (p && typeof p.catch === 'function') p.catch(function(){});
        };
        if (document.readyState === 'complete') {
          setTimeout(loadVideo, 400);
        } else {
          window.addEventListener('load', function () { setTimeout(loadVideo, 400); }, { once: true });
        }
      })();
    </script>

    <!-- Text content. Mobile: below video, centered. Desktop: overlay left. -->
    <div class="hero-text-wrap">
      <div class="hero-content">
        <!-- Desktop-only h1 (mobile h1 is overlaid on video above) -->
        <h1 class="hidden lg:block mb-6 leading-tight drop-shadow-lg">
          <span class="block font-display font-light text-5xl md:text-6xl lg:text-7xl">Making Scripture</span>
          <span class="block font-sans font-bold text-primary text-5xl md:text-6xl lg:text-7xl">Unforgettable</span>
        </h1>
        <p class="font-sans text-lg md:text-xl lg:text-2xl mb-6 lg:mb-5 lg:drop-shadow-md">
          <span class="text-accent lg:text-white font-bold">Word-for-word Scripture.</span><br class="md:hidden" /> <span class="text-primary font-extrabold">Performed live.</span>
        </p>
        <div class="gradient-divider mb-4 lg:mb-16"></div>
        <p class="font-sans text-sm md:text-lg lg:text-xl font-bold uppercase tracking-wide lg:tracking-widest mb-6 md:mb-3 lg:mb-4 text-accent lg:text-white lg:drop-shadow-md">
          Performances | Workshops | Speaking
        </p>
        <p class="font-sans text-sm md:text-base text-gray-600 lg:text-white/90 mb-8 lg:drop-shadow-md">
          For churches, conferences, camps,<br class="md:hidden" /> schools, and special events
        </p>
        <a href="/book-jeremy" class="bg-primary text-gray-900 font-bold font-sans px-10 py-3 lg:px-12 lg:py-4 rounded text-base lg:text-lg transition-all duration-300 hover:opacity-90">
          Book Jeremy
        </a>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE. ENGAGE. EMBODY. — brand pillars with 3 icon tiles.
       NOTE (2026-05-18 100-Club perf rescue): this section was moved ABOVE the
       endorsement carousel so the wide testimonial <p> falls below the mobile
       fold (823px viewport). PSI was treating the carousel <p> as the LCP
       candidate intermittently — bimodal h1 vs <p> picks were causing CLS on
       slow runs. Pillars + H2 are above-fold now; pillar text is short enough
       not to outpaint the hero h1. -->
  <section class="bg-white px-4 py-12 md:py-16">
    <div class="max-w-5xl mx-auto">

      <h2 class="font-sans font-bold text-3xl md:text-4xl lg:text-5xl text-center mb-10">
        <span class="text-accent">Experience. Engage. Embody.</span><br class="hidden md:block" /> <span class="text-primary">God's Word.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

        <div class="flex flex-col items-center text-center">
          <div class="text-primary mb-3 flex justify-center">
            <svg aria-hidden="true" viewBox="0 0 640 512" xmlns="http://www.w3.org/2000/svg" style="width:4rem;height:4rem;fill:currentColor;"><path d="M206.86 245.15c-35.88 10.45-59.95 41.2-57.53 74.1 11.4-12.72 28.81-23.7 49.9-30.92l7.63-43.18zM95.81 295L64.08 115.49c-.29-1.62.28-2.62.24-2.65 57.76-32.06 123.12-49.01 189.01-49.01 1.61 0 3.23.17 4.85.19 13.95-13.47 31.73-22.83 51.59-26 18.89-3.02 38.05-4.55 57.18-5.32-9.99-13.95-24.48-24.23-41.77-27C301.27 1.89 277.24 0 253.32 0 176.66 0 101.02 19.42 33.2 57.06 9.03 70.48-3.92 98.48 1.05 126.58l31.73 179.51c14.23 80.52 136.33 142.08 204.45 142.08 3.59 0 6.75-.46 10.01-.8-13.52-17.08-28.94-40.48-39.5-67.58-47.61-12.98-106.06-51.62-111.93-84.79zm97.55-137.46c-.73-4.12-2.23-7.87-4.07-11.4-8.25 8.91-20.67 15.75-35.32 18.32-14.65 2.58-28.67.4-39.48-5.17-.52 3.94-.64 7.98.09 12.1 3.84 21.7 24.58 36.19 46.34 32.37 21.75-3.82 36.28-24.52 32.44-46.22zM606.8 120.9c-88.98-49.38-191.43-67.41-291.98-51.35-27.31 4.36-49.08 26.26-54.04 54.36l-31.73 179.51c-15.39 87.05 95.28 196.27 158.31 207.35 63.03 11.09 204.47-53.79 219.86-140.84l31.73-179.51c4.97-28.11-7.98-56.11-32.15-69.52zm-273.24 96.8c3.84-21.7 24.58-36.19 46.34-32.36 21.76 3.83 36.28 24.52 32.45 46.22-.73 4.12-2.23 7.87-4.07 11.4-8.25-8.91-20.67-15.75-35.32-18.32-14.65-2.58-28.67-.4-39.48 5.17-.53-3.95-.65-7.99.08-12.11zm70.47 198.76c-55.68-9.79-93.52-59.27-89.04-112.9 20.6 25.54 56.21 46.17 99.49 53.78 43.28 7.61 83.82.37 111.93-16.6-14.18 51.94-66.71 85.51-122.38 75.72zm130.3-151.34c-8.25-8.91-20.68-15.75-35.33-18.32-14.65-2.58-28.67-.4-39.48 5.17-.52-3.94-.64-7.98.09-12.1 3.84-21.7 24.58-36.19 46.34-32.37 21.75 3.83 36.28 24.52 32.45 46.22-.73 4.13-2.23 7.88-4.07 11.4z"/></svg>
          </div>
          <p class="font-sans font-bold text-xl md:text-2xl text-accent">Immersive Storytelling</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="text-primary mb-3 flex justify-center">
            <svg aria-hidden="true" viewBox="0 0 640 512" xmlns="http://www.w3.org/2000/svg" style="width:4rem;height:4rem;fill:currentColor;"><path d="M144 0a80 80 0 1 1 0 160A80 80 0 1 1 144 0zM512 0a80 80 0 1 1 0 160A80 80 0 1 1 512 0zM0 298.7C0 239.8 47.8 192 106.7 192h42.7c15.9 0 31 3.5 44.6 9.7c-1.3 7.2-1.9 14.7-1.9 22.3c0 38.2 16.8 72.5 43.3 96c-.2 0-.4 0-.7 0H21.3C9.6 320 0 310.4 0 298.7zM405.3 320c-.2 0-.4 0-.7 0c26.6-23.5 43.3-57.8 43.3-96c0-7.6-.7-15-1.9-22.3c13.6-6.3 28.7-9.7 44.6-9.7h42.7C592.2 192 640 239.8 640 298.7c0 11.8-9.6 21.3-21.3 21.3H405.3zM224 224a96 96 0 1 1 192 0 96 96 0 1 1 -192 0zM128 485.3C128 411.7 187.7 352 261.3 352H378.7C452.3 352 512 411.7 512 485.3c0 14.7-11.9 26.7-26.7 26.7H154.7c-14.7 0-26.7-11.9-26.7-26.7z"/></svg>
          </div>
          <p class="font-sans font-bold text-xl md:text-2xl text-accent">Interactive Training</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="text-primary mb-3 flex justify-center">
            <svg aria-hidden="true" viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg" style="width:4rem;height:4rem;fill:currentColor;"><path d="M96 96V256c0 53 43 96 96 96s96-43 96-96H208c-8.8 0-16-7.2-16-16s7.2-16 16-16h80V192H208c-8.8 0-16-7.2-16-16s7.2-16 16-16h80V128H208c-8.8 0-16-7.2-16-16s7.2-16 16-16h80c0-53-43-96-96-96S96 43 96 96zM320 240v16c0 70.7-57.3 128-128 128s-128-57.3-128-128V216c0-13.3-10.7-24-24-24s-24 10.7-24 24v40c0 89.1 66.2 162.7 152 174.4V464H120c-13.3 0-24 10.7-24 24s10.7 24 24 24h72 72c13.3 0 24-10.7 24-24s-10.7-24-24-24H216V430.4c85.8-11.7 152-85.3 152-174.4V216c0-13.3-10.7-24-24-24s-24 10.7-24 24v24z"/></svg>
          </div>
          <p class="font-sans font-bold text-xl md:text-2xl text-accent">Impactful Messages</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ENDORSEMENTS CAROUSEL -->
  <section class="bg-cream py-14 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="relative" id="endorsement-track-wrapper">
        <div class="overflow-hidden">
          <div id="endorsement-track" class="flex transition-transform duration-500 ease-in-out">
            {featuredTestimonials.slice(0, 4).map((t: any) => (
              <div class="min-w-full px-10 md:px-12 text-center">
                <p class="text-gray-700 text-base md:text-lg leading-relaxed mb-6 italic">
                  "{t.quote}"
                </p>
                <p class="font-semibold text-accent">{t.authorName}{t.authorTitle ? `, ${t.authorTitle}` : ''}</p>
                <p class="text-sm text-gray-700 font-medium">{t.authorOrganization}</p>
              </div>
            ))}
          </div>
        </div>
        <button
          type="button"
          id="endorsement-prev"
          aria-label="Previous endorsement"
          class="absolute left-0 md:-left-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-primary shadow-md text-gray-900 hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
          </svg>
        </button>
        <button
          type="button"
          id="endorsement-next"
          aria-label="Next endorsement"
          class="absolute right-0 md:-right-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-primary shadow-md text-gray-900 hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </button>
      </div>
      <div id="endorsement-dots" class="flex justify-center gap-1 mt-6" data-total={Math.min(featuredTestimonials.length, 4)}>
        {featuredTestimonials.slice(0, 4).map((_: any, i: number) => (
          <button
            type="button"
            data-index={i}
            class="w-10 h-10 flex items-center justify-center rounded-full"
            aria-label={`Endorsement ${i + 1}`}
          >
            <span class={`block w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-primary' : 'bg-gray-400'}`}></span>
          </button>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/endorsements" class="text-accent font-semibold hover:underline">
          Read More Endorsements →
        </a>
      </div>
    </div>
  </section>

  <!-- DISCOVER THE MINISTRY — section header + 3 service cards -->
  <section class="bg-white px-4 py-12 md:py-16">
    <div class="max-w-5xl mx-auto">

      <!-- Section header with yellow flanking lines -->
      <div class="flex items-center justify-center gap-4 md:gap-6 mb-10">
        <span aria-hidden="true" class="h-1 w-16 md:w-24 bg-primary"></span>
        <h2 class="font-sans font-bold text-3xl md:text-4xl text-accent text-center">Discover<br class="md:hidden" /> the Ministry</h2>
        <span aria-hidden="true" class="h-1 w-16 md:w-24 bg-primary"></span>
      </div>

      <!-- 3 cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden flex flex-col">
          <div class="relative overflow-hidden h-48">
            <img src={performancesImg}
              alt={settings?.homePerformancesAlt || "Scripture Performances"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="p-5 flex flex-col flex-1 items-center text-center md:items-start md:text-left">
            <h3 class="font-sans font-bold text-xl text-accent mb-2">Scripture Performances</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1 md:flex md:flex-col md:justify-center">Immersive, word-for-word dramatizations of entire books, characters, and narratives of the Bible that bring the Word to life.</p>
            <a href="/performances" class="text-accent font-semibold mt-4 hover:underline inline-flex items-center gap-1">
              View Performances <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden flex flex-col">
          <div class="relative overflow-hidden h-48">
            <img src={workshopsImg}
              alt={settings?.homeWorkshopsAlt || "Scripture Memory Workshops"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="p-5 flex flex-col flex-1 items-center text-center md:items-start md:text-left">
            <h3 class="font-sans font-bold text-xl text-accent mb-2">Memory Workshops</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1 md:flex md:flex-col md:justify-center">Engaging, hands-on training to equip people to remember and live out God's Word.</p>
            <a href="/workshops" class="text-accent font-semibold mt-4 hover:underline inline-flex items-center gap-1">
              Explore Workshops <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden flex flex-col">
          <div class="relative overflow-hidden h-48">
            <img src={speakingImg}
              alt={settings?.homeSpeakingAlt || "Guest Speaking"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="p-5 flex flex-col flex-1 items-center text-center md:items-start md:text-left">
            <h3 class="font-sans font-bold text-xl text-accent mb-2">Guest Speaking</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1 md:flex md:flex-col md:justify-center">Dynamic, Scripture-centered messages for churches, camps, conferences, and podcasts.</p>
            <a href="/speaking" class="text-accent font-semibold mt-4 hover:underline inline-flex items-center gap-1">
              See Speaking Topics <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- READY-TO-BOOK CTA — contained blue rounded bar with calendar icon + button -->
  <section class="bg-white py-8 md:py-10 px-4">
    <div class="max-w-5xl mx-auto bg-accent rounded-lg px-6 md:px-10 py-6 md:py-8 flex flex-col md:flex-row items-center md:justify-center gap-4 md:gap-6 text-center">
      <div class="flex flex-col md:flex-row items-center gap-4">
        <div class="text-primary flex-shrink-0">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg" style="width:3rem;height:3rem;fill:currentColor;"><path d="M128 0c17.7 0 32 14.3 32 32V64H288V32c0-17.7 14.3-32 32-32s32 14.3 32 32V64h48c26.5 0 48 21.5 48 48v48H0V112C0 85.5 21.5 64 48 64H96V32c0-17.7 14.3-32 32-32zM0 192H448V464c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V192zm64 80v96c0 8.8 7.2 16 16 16h96c8.8 0 16-7.2 16-16V272c0-8.8-7.2-16-16-16H80c-8.8 0-16 7.2-16 16z"/></svg>
        </div>
        <p class="font-sans font-bold text-xl md:text-2xl text-white">Ready to bring this to your people?</p>
      </div>
      <a href="/book-jeremy" class="bg-primary text-gray-900 font-bold font-sans px-6 py-3 rounded hover:opacity-90 transition-opacity flex-shrink-0">
        Book Jeremy
      </a>
    </div>
  </section>

  <!-- REFER LINE — yellow people icon + refer link -->
  <section class="bg-white py-6 md:py-8 px-4">
    <div class="max-w-5xl mx-auto flex items-center justify-center gap-3 text-center flex-wrap">
      <div class="text-primary flex-shrink-0">
