---
import Layout from '../layouts/Layout.astro';
import { getFeaturedTestimonials } from '../utils/sanity';

const featuredTestimonials = await getFeaturedTestimonials();
const totalSlides = featuredTestimonials.length;
---

<Layout
  title="Performances | Workshops | Preaching | Scripture Alive"
  description="Scripture Alive, a ministry that seeks to engage people with the Word of Truth to impact real lives."
  ogImage="https://assets.spiritmediapublishing.com/scripture-alive/scripturealive-og.png"
>

  <!-- HERO SECTION — full screen, transparent nav shows over video -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden" style="margin-top: -72px;">
    <video
      class="absolute inset-0 w-full h-full object-cover z-0"
      autoplay muted playsinline loop aria-hidden="true"
    >
      <source src="https://assets.spiritmediapublishing.com/scripture-alive/scripture-alive-hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/50 z-10"></div>
    <div class="relative z-20 text-center text-white px-4 max-w-4xl mx-auto">
      <h1 class="font-sans font-bold text-4xl md:text-5xl lg:text-6xl mb-4 text-white drop-shadow-lg">
        Making Scripture Unforgettable
      </h1>
      <p class="font-sans text-xl md:text-2xl mb-10 text-white drop-shadow-md">
        Performances | Workshops | Speaking
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="border-2 border-white text-white font-semibold font-sans px-8 py-3 rounded text-base transition-all duration-300 hover:bg-white hover:text-black">
          Invite Jeremy
        </a>
        <a href="/referjeremy" class="border-2 border-white text-white hover:bg-white hover:text-black font-semibold font-sans px-8 py-3 rounded text-base transition-all duration-300">
          Refer Jeremy
        </a>
      </div>
    </div>
  </section>

  <!-- DEDICATED TO PROCLAIMING — blue heading -->
  <section class="bg-white pt-16 pb-8 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="font-sans font-bold text-2xl md:text-3xl lg:text-4xl leading-tight text-accent">
        Dedicated to Proclaiming the Word with Creativity and Conviction
      </h2>
    </div>
  </section>

  <!-- FOUR FEATURES -->
  <section class="bg-white py-8 px-4 pb-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M448 358.4V25.6c0-16-9.6-25.6-25.6-25.6H96C41.6 0 0 41.6 0 96v320c0 54.4 41.6 96 96 96h326.4c12.8 0 25.6-9.6 25.6-25.6v-16c0-6.4-3.2-12.8-9.6-19.2-3.2-16-3.2-60.8 0-73.6 6.4-3.2 9.6-9.6 9.6-19.2zM144 144c0-8.84 7.16-16 16-16h48V80c0-8.84 7.16-16 16-16h32c8.84 0 16 7.16 16 16v48h48c8.84 0 16 7.16 16 16v32c0 8.84-7.16 16-16 16h-48v112c0 8.84-7.16 16-16 16h-32c-8.84 0-16-7.16-16-16V192h-48c-8.84 0-16-7.16-16-16v-32zm236.8 304H96c-19.2 0-32-12.8-32-32s16-32 32-32h284.8v64z"/></svg>
        </div>
        <h3 class="font-sans font-semibold text-base mb-2 text-accent">Pure Scripture</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Every performance is quoted word for word from the Bible.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 640 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M206.86 245.15c-35.88 10.45-59.95 41.2-57.53 74.1 11.4-12.72 28.81-23.7 49.9-30.92l7.63-43.18zM95.81 295L64.08 115.49c-.29-1.62.28-2.62.24-2.65 57.76-32.06 123.12-49.01 189.01-49.01 1.61 0 3.23.17 4.85.19 13.95-13.47 31.73-22.83 51.59-26 18.89-3.02 38.05-4.55 57.18-5.32-9.99-13.95-24.48-24.23-41.77-27C301.27 1.89 277.24 0 253.32 0 176.66 0 101.02 19.42 33.2 57.06 9.03 70.48-3.92 98.48 1.05 126.58l31.73 179.51c14.23 80.52 136.33 142.08 204.45 142.08 3.59 0 6.75-.46 10.01-.8-13.52-17.08-28.94-40.48-39.5-67.58-47.61-12.98-106.06-51.62-111.93-84.79zm97.55-137.46c-.73-4.12-2.23-7.87-4.07-11.4-8.25 8.91-20.67 15.75-35.32 18.32-14.65 2.58-28.67.4-39.48-5.17-.52 3.94-.64 7.98.09 12.1 3.84 21.7 24.58 36.19 46.34 32.37 21.75-3.82 36.28-24.52 32.44-46.22zM606.8 120.9c-88.98-49.38-191.43-67.41-291.98-51.35-27.31 4.36-49.08 26.26-54.04 54.36l-31.73 179.51c-15.39 87.05 95.28 196.27 158.31 207.35 63.03 11.09 204.47-53.79 219.86-140.84l31.73-179.51c4.97-28.11-7.98-56.11-32.15-69.52zm-273.24 96.8c3.84-21.7 24.58-36.19 46.34-32.36 21.76 3.83 36.28 24.52 32.45 46.22-.73 4.12-2.23 7.87-4.07 11.4-8.25-8.91-20.67-15.75-35.32-18.32-14.65-2.58-28.67-.4-39.48 5.17-.53-3.95-.65-7.99.08-12.11zm70.47 198.76c-55.68-9.79-93.52-59.27-89.04-112.9 20.6 25.54 56.21 46.17 99.49 53.78 43.28 7.61 83.82.37 111.93-16.6-14.18 51.94-66.71 85.51-122.38 75.72zm130.3-151.34c-8.25-8.91-20.68-15.75-35.33-18.32-14.65-2.58-28.67-.4-39.48 5.17-.52-3.94-.64-7.98.09-12.1 3.84-21.7 24.58-36.19 46.34-32.37 21.75 3.83 36.28 24.52 32.45 46.22-.73 4.13-2.23 7.88-4.07 11.4z"/></svg>
        </div>
        <h3 class="font-sans font-semibold text-base mb-2 text-accent">Skillfully Dramatized</h3>
        <p class="text-gray-600 text-sm leading-relaxed">A high-quality theatrical production makes Scripture leap off of the page.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 576 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M96,128A64,64,0,1,0,32,64,64,64,0,0,0,96,128Zm0,176.08a44.11,44.11,0,0,1,13.64-32L181.77,204c1.65-1.55,3.77-2.31,5.61-3.57A63.91,63.91,0,0,0,128,160H64A64,64,0,0,0,0,224v96a32,32,0,0,0,32,32V480a32,32,0,0,0,32,32h64a32,32,0,0,0,32-32V383.61l-50.36-47.53A44.08,44.08,0,0,1,96,304.08ZM480,128a64,64,0,1,0-64-64A64,64,0,0,0,480,128Zm32,32H448a63.91,63.91,0,0,0-59.38,40.42c1.84,1.27,4,2,5.62,3.59l72.12,68.06a44.37,44.37,0,0,1,0,64L416,383.62V480a32,32,0,0,0,32,32h64a32,32,0,0,0,32-32V352a32,32,0,0,0,32-32V224A64,64,0,0,0,512,160ZM444.4,295.34l-72.12-68.06A12,12,0,0,0,352,236v36H224V236a12,12,0,0,0-20.28-8.73L131.6,295.34a12.4,12.4,0,0,0,0,17.47l72.12,68.07A12,12,0,0,0,224,372.14V336H352v36.14a12,12,0,0,0,20.28,8.74l72.12-68.07A12.4,12.4,0,0,0,444.4,295.34Z"/></svg>
        </div>
        <h3 class="font-sans font-semibold text-base mb-2 text-accent">Impacting Lives</h3>
        <p class="text-gray-600 text-sm leading-relaxed">People regularly say how moved they are and how it helps them better understand the Bible.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M120 72c0-39.765 32.235-72 72-72s72 32.235 72 72c0 39.764-32.235 72-72 72s-72-32.236-72-72zm254.627 1.373c-12.496-12.497-32.758-12.497-45.254 0L242.745 160H141.254L54.627 73.373c-12.496-12.497-32.758-12.497-45.254 0-12.497 12.497-12.497 32.758 0 45.255L104 213.254V480c0 17.673 14.327 32 32 32h16c17.673 0 32-14.327 32-32V368h16v112c0 17.673 14.327 32 32 32h16c17.673 0 32-14.327 32-32V213.254l94.627-94.627c12.497-12.497 12.497-32.757 0-45.254z"/></svg>
        </div>
        <h3 class="font-sans font-semibold text-base mb-2 text-accent">Unique and Memorable</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Your audience will never forget when Scripture is dramatically presented!</p>
      </div>

    </div>
  </section>

  <!-- SERVICE TILES -->
  <section class="bg-white px-4 pb-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4">

      <a href="/performances" class="relative overflow-hidden group block h-48 rounded">
        <img src="https://assets.spiritmediapublishing.com/scripture-alive/2107248e6e6621d6b4fe5c38c18c8cd5_1200_80-rdodoupy1h2rw6xw4mrrs0ezpy6gn7vm8zl0kghkru.webp"
          alt="Scripture Performances" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
      </a>

      <a href="/workshops" class="relative overflow-hidden group block h-48 rounded">
        <img src="https://assets.spiritmediapublishing.com/scripture-alive/7dea0315c3929177440f5d9a90340ce8_1200_80-rdodoupy1h2rw6xw4mrrs0ezpy6gn7vm8zl0kghkru.webp"
          alt="Scripture Memory Workshops" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
      </a>

      <a href="/guest-preaching" class="relative overflow-hidden group block h-48 rounded">
        <img src="https://assets.spiritmediapublishing.com/scripture-alive/f851f13fa9d3e0e5887f74730556c3d0_1200_80-rdodoupy1h2rw6xw4mrrs0ezpy6gn7vm8zl0kghkru.webp"
          alt="Guest Preaching" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
      </a>

    </div>
  </section>

  <!-- TESTIMONIALS CAROUSEL -->
  <section class="bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="relative overflow-hidden" id="testimonial-track-wrapper">
        <div id="testimonial-track" class="flex transition-transform duration-500 ease-in-out">
          {featuredTestimonials.map((t: any) => (
            <div class="min-w-full px-4 text-center">
              <p class="text-gray-700 text-base md:text-lg leading-relaxed mb-6 italic">
                "{t.quote}"
              </p>
              <p class="font-semibold text-gray-900">{t.authorName}{t.authorTitle ? `, ${t.authorTitle}` : ''}</p>
              <p class="text-sm text-gray-500">{t.authorOrganization}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots -->
      <div id="testimonial-dots" class="flex justify-center gap-2 mt-8" data-total={totalSlides}>
        {featuredTestimonials.map((_: any, i: number) => (
          <button
            data-index={i}
            class={`w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-primary' : 'bg-gray-300'}`}
            aria-label={`Testimonial ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById('testimonial-track');
    const dotsContainer = document.getElementById('testimonial-dots');
    const dots = dotsContainer?.querySelectorAll('button') ?? [];
    let current = 0;
    const total = Number(dotsContainer?.dataset.total ?? dots.length);

    function goTo(n) {
      current = (n + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        d.classList.toggle('bg-primary', i === current);
        d.classList.toggle('bg-gray-300', i !== current);
      });
    }

    dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.dataset.index))));
    setInterval(() => goTo(current + 1), 5000);
  </script>

</Layout>