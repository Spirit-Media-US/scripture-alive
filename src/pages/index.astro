---
import Layout from "../layouts/Layout.astro";
import { getFeaturedTestimonials, getSiteSettings } from "../utils/sanity";

const featuredTestimonials = await getFeaturedTestimonials();
const settings = await getSiteSettings();
const totalSlides = featuredTestimonials.length;

// Apply Sanity CDN transforms. Service tiles display at ~320×192 (h-48 in a
// 3-col grid on lg+, max-w-5xl) so DPR 2 fetches should be 640×384 — matching
// the width/height attrs on the <img>.
const tileTransform = (url: string | undefined, fallback: string) => {
	const base = url || fallback;
	if (!base.includes("cdn.sanity.io")) return base;
	const sep = base.includes("?") ? "&" : "?";
	return `${base}${sep}w=640&h=384&fit=crop&fm=webp&q=75`;
};
const performancesImg = tileTransform(
	settings?.homePerformancesImage,
	"https://cdn.sanity.io/images/vxczpihg/production/77e01b90ecf67d8a98bd7b81065106b062648bf3-354x177.webp",
);
const workshopsImg = tileTransform(
	settings?.homeWorkshopsImage,
	"https://cdn.sanity.io/images/vxczpihg/production/adab64545b5f89913fecdfea364d41c884f063cc-354x177.webp",
);
const speakingImg = tileTransform(
	settings?.homeSpeakingImage,
	"https://cdn.sanity.io/images/vxczpihg/production/8e31433446554b2eb54ea4a475dec26aa0af6dcd-354x177.webp",
);
---

<Layout
  title="Performances | Workshops | Preaching | Scripture Alive"
  description="Scripture Alive, a ministry that seeks to engage people with the Word of Truth to impact real lives."
  ogImage="https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png"
  jsonld={{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Scripture Alive",
    "url": "https://scripturealive.com",
    "logo": "https://cdn.sanity.io/images/vxczpihg/production/f95c2c1a3f77a64e7803bfcdc3138cc7a28937be-200x100.webp",
    "description": "Scripture Alive is a ministry that engages people with the Word of Truth through dramatic performances, Bible memorization workshops, and guest preaching.",
    "sameAs": ["https://scripturealive.com"],
    "founder": {
      "@type": "Person",
      "name": "Jeremy Kluth"
    }
  }}
>

  <Fragment slot="head">
    <!-- No hero image preload: LCP is now the H1 text (paints from HTML stream
         ~800ms slow-4G vs 2.93s for the image). The hero photo below is
         loading="lazy" and below the fold, removing it from LCP candidates.
         Preload Montserrat 500 here for the Book Jeremy button weight. -->
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/montserrat/montserrat-500.woff2" crossorigin />
  </Fragment>

  <!-- HERO TEXT BAND — H1 paints from the HTML stream, becoming the LCP.
       Solid cream background means no image download is on the LCP path. -->
  <section class="bg-cream pt-16 pb-12 md:pt-24 md:pb-16 lg:pt-28 lg:pb-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="font-display font-light text-5xl md:text-6xl lg:text-7xl leading-tight text-accent">
        Making Scripture Unforgettable
      </h1>
      <p class="font-sans text-base sm:text-xl md:text-2xl mt-6 text-gray-700">
        Performances | Workshops | Speaking
      </p>
      <p class="font-sans text-sm md:text-base mt-3 text-gray-600">
        Available for churches, conferences, camps, schools, and special events
      </p>
      <div class="flex flex-col items-center gap-3 mt-8">
        <a href="/book-jeremy" class="bg-primary text-black font-semibold font-sans px-10 py-3 rounded text-base transition-all duration-300 hover:opacity-90">
          Book Jeremy
        </a>
        <a href="/referjeremy" class="text-gray-700 text-sm hover:text-accent transition-colors">
          Know someone who should hear about Jeremy? <span class="underline">Refer him here</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HERO IMAGE BANNER — banner below the text band. loading="lazy" + below-fold
       keeps it out of the LCP candidate pool. The video overlay still runs (desktop
       only) once the user gets here and the page has idled. -->
  <section class="relative overflow-hidden bg-cream">
    <img
      src="https://assets.spiritmediapublishing.com/scripture-alive/hero-800.webp"
      srcset="https://assets.spiritmediapublishing.com/scripture-alive/hero-800.webp 800w, https://assets.spiritmediapublishing.com/scripture-alive/hero-1600.webp 1600w"
      sizes="(max-width:1023px) 400px, 1440px"
      width="1600"
      height="500"
      alt="Jeremy Kluth performing Scripture Alive"
      loading="lazy"
      decoding="async"
      class="w-full max-h-[280px] md:max-h-[460px] lg:max-h-[560px] object-cover"
      id="hero-poster"
    />
    <video
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
      muted playsinline loop preload="none" aria-hidden="true"
      id="hero-video"
      data-src="https://assets.spiritmediapublishing.com/scripture-alive/scripture-alive-hero.mp4"
    ></video>
  </section>

  <!-- DEDICATED TO PROCLAIMING — blue heading -->
  <section class="bg-white pt-16 pb-8 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl leading-tight text-accent">
        Dedicated to Proclaiming the Word with Creativity and Conviction
      </h2>
    </div>
  </section>

  <!-- FOUR FEATURES -->
  <section class="bg-white py-8 px-4 pb-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M448 358.4V25.6c0-16-9.6-25.6-25.6-25.6H96C41.6 0 0 41.6 0 96v320c0 54.4 41.6 96 96 96h326.4c12.8 0 25.6-9.6 25.6-25.6v-16c0-6.4-3.2-12.8-9.6-19.2-3.2-16-3.2-60.8 0-73.6 6.4-3.2 9.6-9.6 9.6-19.2zM144 144c0-8.84 7.16-16 16-16h48V80c0-8.84 7.16-16 16-16h32c8.84 0 16 7.16 16 16v48h48c8.84 0 16 7.16 16 16v32c0 8.84-7.16 16-16 16h-48v112c0 8.84-7.16 16-16 16h-32c-8.84 0-16-7.16-16-16V192h-48c-8.84 0-16-7.16-16-16v-32zm236.8 304H96c-19.2 0-32-12.8-32-32s16-32 32-32h284.8v64z"/></svg>
        </div>
        <h2 class="font-sans font-bold text-lg mb-2 text-accent">Pure Scripture</h2>
        <p class="text-gray-600 leading-relaxed">Every performance is quoted word for word from the Bible.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 640 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M206.86 245.15c-35.88 10.45-59.95 41.2-57.53 74.1 11.4-12.72 28.81-23.7 49.9-30.92l7.63-43.18zM95.81 295L64.08 115.49c-.29-1.62.28-2.62.24-2.65 57.76-32.06 123.12-49.01 189.01-49.01 1.61 0 3.23.17 4.85.19 13.95-13.47 31.73-22.83 51.59-26 18.89-3.02 38.05-4.55 57.18-5.32-9.99-13.95-24.48-24.23-41.77-27C301.27 1.89 277.24 0 253.32 0 176.66 0 101.02 19.42 33.2 57.06 9.03 70.48-3.92 98.48 1.05 126.58l31.73 179.51c14.23 80.52 136.33 142.08 204.45 142.08 3.59 0 6.75-.46 10.01-.8-13.52-17.08-28.94-40.48-39.5-67.58-47.61-12.98-106.06-51.62-111.93-84.79zm97.55-137.46c-.73-4.12-2.23-7.87-4.07-11.4-8.25 8.91-20.67 15.75-35.32 18.32-14.65 2.58-28.67.4-39.48-5.17-.52 3.94-.64 7.98.09 12.1 3.84 21.7 24.58 36.19 46.34 32.37 21.75-3.82 36.28-24.52 32.44-46.22zM606.8 120.9c-88.98-49.38-191.43-67.41-291.98-51.35-27.31 4.36-49.08 26.26-54.04 54.36l-31.73 179.51c-15.39 87.05 95.28 196.27 158.31 207.35 63.03 11.09 204.47-53.79 219.86-140.84l31.73-179.51c4.97-28.11-7.98-56.11-32.15-69.52zm-273.24 96.8c3.84-21.7 24.58-36.19 46.34-32.36 21.76 3.83 36.28 24.52 32.45 46.22-.73 4.12-2.23 7.87-4.07 11.4-8.25-8.91-20.67-15.75-35.32-18.32-14.65-2.58-28.67-.4-39.48 5.17-.53-3.95-.65-7.99.08-12.11zm70.47 198.76c-55.68-9.79-93.52-59.27-89.04-112.9 20.6 25.54 56.21 46.17 99.49 53.78 43.28 7.61 83.82.37 111.93-16.6-14.18 51.94-66.71 85.51-122.38 75.72zm130.3-151.34c-8.25-8.91-20.68-15.75-35.33-18.32-14.65-2.58-28.67-.4-39.48 5.17-.52-3.94-.64-7.98.09-12.1 3.84-21.7 24.58-36.19 46.34-32.37 21.75 3.83 36.28 24.52 32.45 46.22-.73 4.13-2.23 7.88-4.07 11.4z"/></svg>
        </div>
        <h2 class="font-sans font-bold text-lg mb-2 text-accent">Skillfully Dramatized</h2>
        <p class="text-gray-600 leading-relaxed">A high-quality theatrical production makes Scripture leap off of the page.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 576 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M96,128A64,64,0,1,0,32,64,64,64,0,0,0,96,128Zm0,176.08a44.11,44.11,0,0,1,13.64-32L181.77,204c1.65-1.55,3.77-2.31,5.61-3.57A63.91,63.91,0,0,0,128,160H64A64,64,0,0,0,0,224v96a32,32,0,0,0,32,32V480a32,32,0,0,0,32,32h64a32,32,0,0,0,32-32V383.61l-50.36-47.53A44.08,44.08,0,0,1,96,304.08ZM480,128a64,64,0,1,0-64-64A64,64,0,0,0,480,128Zm32,32H448a63.91,63.91,0,0,0-59.38,40.42c1.84,1.27,4,2,5.62,3.59l72.12,68.06a44.37,44.37,0,0,1,0,64L416,383.62V480a32,32,0,0,0,32,32h64a32,32,0,0,0,32-32V352a32,32,0,0,0,32-32V224A64,64,0,0,0,512,160ZM444.4,295.34l-72.12-68.06A12,12,0,0,0,352,236v36H224V236a12,12,0,0,0-20.28-8.73L131.6,295.34a12.4,12.4,0,0,0,0,17.47l72.12,68.07A12,12,0,0,0,224,372.14V336H352v36.14a12,12,0,0,0,20.28,8.74l72.12-68.07A12.4,12.4,0,0,0,444.4,295.34Z"/></svg>
        </div>
        <h2 class="font-sans font-bold text-lg mb-2 text-accent">Impacting Lives</h2>
        <p class="text-gray-600 leading-relaxed">People regularly say how moved they are and how it helps them better understand the Bible.</p>
      </div>

      <div class="flex flex-col items-center text-center p-6 border border-gray-200 rounded-lg shadow">
        <div class="mb-4 flex items-center justify-center text-primary">
          <svg aria-hidden="true" viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;fill:currentColor;"><path d="M120 72c0-39.765 32.235-72 72-72s72 32.235 72 72c0 39.764-32.235 72-72 72s-72-32.236-72-72zm254.627 1.373c-12.496-12.497-32.758-12.497-45.254 0L242.745 160H141.254L54.627 73.373c-12.496-12.497-32.758-12.497-45.254 0-12.497 12.497-12.497 32.758 0 45.255L104 213.254V480c0 17.673 14.327 32 32 32h16c17.673 0 32-14.327 32-32V368h16v112c0 17.673 14.327 32 32 32h16c17.673 0 32-14.327 32-32V213.254l94.627-94.627c12.497-12.497 12.497-32.757 0-45.254z"/></svg>
        </div>
        <h2 class="font-sans font-bold text-lg mb-2 text-accent">Unique and Memorable</h2>
        <p class="text-gray-600 leading-relaxed">Your audience will never forget when Scripture is dramatically presented!</p>
      </div>

    </div>
  </section>

  <!-- ENDORSEMENTS CAROUSEL -->
  <section class="bg-cream py-14 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="relative overflow-hidden" id="endorsement-track-wrapper">
        <div id="endorsement-track" class="flex transition-transform duration-500 ease-in-out">
          {featuredTestimonials.slice(0, 4).map((t: any) => (
            <div class="min-w-full px-4 text-center">
              <p class="text-gray-700 text-base md:text-lg leading-relaxed mb-6 italic">
                "{t.quote}"
              </p>
              <p class="font-semibold text-accent">{t.authorName}{t.authorTitle ? `, ${t.authorTitle}` : ''}</p>
              <p class="text-sm text-gray-700 font-medium">{t.authorOrganization}</p>
            </div>
          ))}
        </div>
      </div>
      <div id="endorsement-dots" class="flex justify-center gap-1 mt-6" data-total={Math.min(featuredTestimonials.length, 4)}>
        {featuredTestimonials.slice(0, 4).map((_: any, i: number) => (
          <button
            type="button"
            data-index={i}
            class="w-10 h-10 flex items-center justify-center rounded-full"
            aria-label={`Endorsement ${i + 1}`}
          >
            <span class={`block w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-primary' : 'bg-gray-400'}`}></span>
          </button>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/endorsements" class="text-accent font-semibold hover:underline">
          Read More Endorsements →
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICE TILES -->
  <section class="bg-white px-4 py-10">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6">

      <a href="/performances" class="block group text-center">
        <div class="relative overflow-hidden rounded h-48">
          <img src={performancesImg}
            alt={settings?.homePerformancesAlt || "Scripture Performances"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <h3 class="font-bold text-lg text-accent font-sans mt-3 mb-1">Performances</h3>
        <p class="text-gray-600 text-sm">Full books of the Bible performed word-for-word from memory.</p>
      </a>

      <a href="/workshops" class="block group text-center">
        <div class="relative overflow-hidden rounded h-48">
          <img src={workshopsImg}
            alt={settings?.homeWorkshopsAlt || "Scripture Memory Workshops"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <h3 class="font-bold text-lg text-accent font-sans mt-3 mb-1">Workshops</h3>
        <p class="text-gray-600 text-sm">Hands-on sessions that equip people to memorize Scripture and live it out.</p>
      </a>

      <a href="/speaking" class="block group text-center">
        <div class="relative overflow-hidden rounded h-48">
          <img src={speakingImg}
            alt={settings?.homeSpeakingAlt || "Guest Speaking"} width="640" height="384" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <h3 class="font-bold text-lg text-accent font-sans mt-3 mb-1">Speaking</h3>
        <p class="text-gray-600 text-sm">Powerful spoken messages for churches, camps, podcasts, and events.</p>
      </a>

    </div>
  </section>

  <script>
    // Hero video: 15MB MP4 — only load on desktop-class devices. Mobile keeps
    // the static hero image (LCP) to protect PSI mobile Perf: Lighthouse captures
    // post-load traffic, and 15MB in that window destroys total-byte-weight score.
    //
    // Gates: >= 1024px viewport AND non-mobile DPR pattern AND connection isn't
    // save-data or 2g/3g. Desktop visitors get the video; mobile visitors get a
    // high-quality still. Kevin's brand video plays on the pages that need it
    // (performances, etc.), not as homepage LCP decoration.
    function loadHeroVideo() {
      const video = document.getElementById('hero-video') as HTMLVideoElement | null;
      if (!video || video.dataset.loaded === '1') return;
      // Width gate: desktop only
      if (window.innerWidth < 1024) return;
      // Data-saver / slow connection gate
      const conn = (navigator as any).connection;
      if (conn) {
        if (conn.saveData) return;
        if (conn.effectiveType && /2g|3g/i.test(conn.effectiveType)) return;
      }
      video.dataset.loaded = '1';
      const src = video.dataset.src;
      if (!src) return;
      const source = document.createElement('source');
      source.src = src;
      source.type = 'video/mp4';
      video.appendChild(source);
      video.preload = 'auto';
      video.load();
      video.play().catch(() => { /* autoplay may be blocked; poster stays */ });
      // Video layers above the poster at the same z-index; just fade the video in.
      // Do NOT mutate poster opacity — Lighthouse snapshots the LCP element after
      // load, and opacity:0 makes the LCP element look unpainted.
      video.addEventListener('playing', () => {
        video.classList.remove('opacity-0');
      }, { once: true });
    }
    window.addEventListener('load', () => {
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(loadHeroVideo, { timeout: 2000 });
      } else {
        setTimeout(loadHeroVideo, 1500);
      }
    });

    const track = document.getElementById('endorsement-track');
    const dotsContainer = document.getElementById('endorsement-dots');
    const dots = dotsContainer?.querySelectorAll('button') ?? [];
    let current = 0;
    const total = Number(dotsContainer?.dataset.total ?? dots.length);

    function goTo(n) {
      current = (n + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        const inner = d.querySelector('span');
        if (!inner) return;
        inner.classList.toggle('bg-primary', i === current);
        inner.classList.toggle('bg-gray-400', i !== current);
      });
    }

    dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.dataset.index))));
    setInterval(() => goTo(current + 1), 5000);
  </script>

</Layout>