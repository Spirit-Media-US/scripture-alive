---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../utils/sanity";

const title = "Scripture Alive Store | Memorization Tools";
const description =
	"Browse our store for curated tools and aids designed to help you memorize the Bible.";
const jsonld = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: "Scripture Alive Store | Memorization Tools",
	url: "https://scripturealive.com/store",
	description:
		"Browse our store for curated tools and aids designed to help you memorize the Bible.",
	about: {
		"@type": "Organization",
		name: "Scripture Alive",
		url: "https://scripturealive.com",
	},
};
const ogImage =
	"https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png";

// Fallback images by order (until uploaded to Sanity)
const fallbackImages: Record<number, string> = {
	1: "https://cdn.sanity.io/images/vxczpihg/production/b13f77817d2b1138fa335c10696ebc0f1e1e1cbe-232x327.webp",
	2: "https://cdn.sanity.io/images/vxczpihg/production/5f106f9f819f5b5a049a486b74d188b552eb48e8-210x334.webp",
	3: "https://cdn.sanity.io/images/vxczpihg/production/5f106f9f819f5b5a049a486b74d188b552eb48e8-210x334.webp",
	4: "https://cdn.sanity.io/images/vxczpihg/production/5f106f9f819f5b5a049a486b74d188b552eb48e8-210x334.webp",
	5: "https://cdn.sanity.io/images/vxczpihg/production/63b8fe9eb83a87aeed2e5588dab95142b530695c-210x334.png",
	6: "https://cdn.sanity.io/images/vxczpihg/production/63b8fe9eb83a87aeed2e5588dab95142b530695c-210x334.png",
	7: "https://cdn.sanity.io/images/vxczpihg/production/5f106f9f819f5b5a049a486b74d188b552eb48e8-210x334.webp",
	8: "https://cdn.sanity.io/images/vxczpihg/production/a584ad3148fc1395f8d59392c6226e04d2fda588-210x335.png",
};

const products = await getProducts();
---

<Layout title={title} description={description} ogImage={ogImage} jsonld={jsonld}>

  <h1 class="sr-only">Scripture Alive Store — Scripture Memory Tools</h1>

  <!-- Hero Banner -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <img
        src={"https://assets.spiritmediapublishing.com/scripture-alive/store-header.webp"}
        alt="Jeremy Kluth's No More Excuses - Power Tools for Scripture Memory"
        class="w-full rounded"
        loading="eager"
      />
    </div>
  </section>

  <!-- Products Grid -->
  <section class="bg-white py-12">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {products.map((product: any) => {
          const imgSrc = fallbackImages[product.order] ?? fallbackImages[1];
          return (
            <div class="flex flex-col items-center text-center">
              <div class="w-full overflow-hidden mb-4">
                <img
                  src={imgSrc}
                  alt={product.title}
                  class="w-full h-auto object-cover"
                  loading="lazy"
                />
              </div>
              <h3 class="text-sm font-bold text-gray-900 leading-snug mb-1 font-sans">{product.title}</h3>
              <div class="mb-3"></div>
              {product.comingSoon === 'available' && product.storeUrl ? (
                <a
                  href={product.storeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block bg-accent text-white font-semibold px-5 py-2 rounded text-sm hover:bg-accent/85 transition-colors mt-auto"
                >
                  View Product
                </a>
              ) : product.comingSoon === 'coming_soon' ? (
                <span class="inline-block bg-gray-200 text-gray-600 font-semibold px-5 py-2 rounded text-sm mt-auto">
                  Coming Soon
                </span>
              ) : null}
            </div>
          );
        })}
      </div>
    </div>
  </section>

</Layout>
