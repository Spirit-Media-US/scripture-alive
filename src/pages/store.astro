---
import Layout from '../layouts/Layout.astro';
import { getProducts } from '../utils/sanity';

const title = "Scripture Alive Store | Memorization Tools";
const description = "Browse our store for curated tools and aids designed to help you memorize the Bible.";
const ogImage = "https://assets.spiritmediapublishing.com/scripture-alive/scripturealive-og.png";

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";

// Fallback images by order (until uploaded to Sanity)
const fallbackImages: Record<number, string> = {
  1: `${BASE}/dd62f7369bcde9f6588eeddd8137695b_1200_80-rdodoupwjyz0ovcd8day09jlq35efnron1w2c5o2bq.webp`,
  2: `${BASE}/265afdcfbaeab3fe5e3d18f1df843d18_1200_80-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.webp`,
  3: `${BASE}/265afdcfbaeab3fe5e3d18f1df843d18_1200_80-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.webp`,
  4: `${BASE}/265afdcfbaeab3fe5e3d18f1df843d18_1200_80-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.webp`,
  5: `${BASE}/PTR-Work-Booklet-FINAL-1167-x-1646-px-1200-x-1914-px-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.png`,
  6: `${BASE}/PTR-Work-Booklet-FINAL-1167-x-1646-px-1200-x-1914-px-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.png`,
  7: `${BASE}/265afdcfbaeab3fe5e3d18f1df843d18_1200_80-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrg.webp`,
  8: `${BASE}/Power-Toolkit-APP-8.0-rdodoupwabn4mykaey0tthokdpvrlywabfag8asrrq.png`,
};

const products = await getProducts();
---

<Layout title={title} description={description} ogImage={ogImage}>

  <h1 class="sr-only">Scripture Alive Store — Scripture Memory Tools</h1>

  <!-- Hero Banner -->
  <section class="w-full">
    <img
      src={`${BASE}/b935343b78a571e3a47c0bcf57790708_1200_80.webp`}
      alt="Jeremy Kluth's No More Excuses - Power Tools for Scripture Memory"
      class="w-full object-cover"
      loading="eager"
    />
  </section>

  <!-- Products Grid -->
  <section class="bg-white py-12">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {products.map((product: any) => {
          const imgSrc = fallbackImages[product.order] ?? fallbackImages[1];
          return (
            <div class="flex flex-col items-center text-center">
              <div class="w-full overflow-hidden mb-4">
                <img
                  src={imgSrc}
                  alt={product.title}
                  class="w-full h-auto object-cover"
                  loading="lazy"
                />
              </div>
              <h3 class="text-sm font-bold text-gray-900 leading-snug mb-1">{product.title}</h3>
              {product.price && (
                <p class="text-sm text-gray-800 mb-3">{product.price}</p>
              )}
              {!product.price && <div class="mb-3"></div>}
              {product.comingSoon === 'available' && product.storeUrl ? (
                <a
                  href={product.storeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block bg-gold text-white font-semibold px-5 py-2 rounded text-sm hover:bg-gold/85 transition-colors mt-auto"
                >
                  View Product
                </a>
              ) : product.comingSoon === 'coming_soon' ? (
                <span class="inline-block bg-gray-200 text-gray-600 font-semibold px-5 py-2 rounded text-sm mt-auto">
                  Coming Soon
                </span>
              ) : null}
            </div>
          );
        })}
      </div>
    </div>
  </section>

</Layout>
