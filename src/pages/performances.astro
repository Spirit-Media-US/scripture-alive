---
import Layout from "../layouts/Layout.astro";
import { getPerformances } from "../utils/sanity";

const performances = await getPerformances();

// Map Sanity order → category
const categoryMap: Record<number, string> = {
	1: "Books",
	2: "Books",
	3: "Characters",
	4: "Characters",
	5: "Characters",
	6: "Stories",
	7: "Stories",
	8: "Stories",
	9: "Books",
};

const categoryHref: Record<string, string> = {
	Books: "/performances/books",
	Characters: "/performances/characters",
	Stories: "/performances/stories",
};

type Performance = {
	_id: string;
	title: string;
	imageUrl: string | null;
	order: number;
};

const categories = ["Books", "Characters", "Stories"].map((name) => ({
	name,
	href: categoryHref[name],
	tiles: performances
		.filter((p: Performance) => categoryMap[p.order] === name)
		.sort((a: Performance, b: Performance) => a.order - b.order),
}));
---

<Layout
  title="Live Scripture Performances | Scripture Alive"
  description="Compelling word-for-word dramatizations taken directly from the Bible — Books, Characters, and Stories performed live."
  jsonld={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Live Scripture Performances | Scripture Alive",
    "url": "https://scripturealive.com/performances",
    "description": "Compelling word-for-word dramatizations taken directly from the Bible.",
    "about": {
      "@type": "Organization",
      "name": "Scripture Alive",
      "url": "https://scripturealive.com"
    }
  }}
  ogImage={performances[0]?.imageUrl ?? ""}
>

  <!-- Page Heading -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-4">
        Live Scripture Performances
      </h1>
      <p class="text-base md:text-lg text-gray-500 leading-relaxed">
        Compelling word-for-word dramatizations taken directly from the Bible
      </p>
    </div>
  </section>

  <!-- Category Sections -->
  {categories.map((cat) => (
    <section class="py-10 px-4 bg-cream">
      <div class="max-w-4xl mx-auto">

        <!-- Category name -->
        <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-6">
          {cat.name}
        </h2>

        <!-- 3 image tiles -->
        <div class="grid grid-cols-3 gap-4 mb-6">
          {cat.tiles.map((tile: Performance) => (
            <a href={cat.href} class="block cursor-pointer rounded overflow-hidden group">
              {tile.imageUrl ? (
                <img
                  src={tile.imageUrl}
                  alt={tile.title}
                  loading="lazy"
                  class="w-full h-[180px] object-cover rounded group-hover:opacity-90 transition-opacity"
                />
              ) : (
                <div class="w-full h-[180px] bg-gray-800 rounded flex items-center justify-center group-hover:opacity-90 transition-opacity">
                  <span class="text-white text-sm font-semibold text-center px-3 leading-snug">
                    {tile.title}
                  </span>
                </div>
              )}
            </a>
          ))}
        </div>

        <!-- Learn More button -->
        <div class="text-center">
          <a
            href={cat.href}
            class="inline-block bg-accent text-white font-semibold px-8 py-2 rounded hover:opacity-90 transition-opacity"
          >
            Learn More
          </a>
        </div>

      </div>
    </section>
  ))}

  <!-- Book A Performance -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-3xl mx-auto">
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-black font-bold px-12 py-4 rounded text-lg hover:opacity-90 transition-opacity"
      >
        Book A Performance
      </a>
    </div>
  </section>

</Layout>
