---
import Layout from "../../layouts/Layout.astro";

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";

const characters = [
	{
		title: "Paul",
		description:
			"Step into the sandals of the Apostle Paul — a first-person performance drawn from Paul's letters and Acts. Experience the passion, the persecution, and the unshakable faith of one of history's greatest missionaries.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/5b5f24412ee24413a1313218d7f147eee363b941-1024x682.webp",
	},
	{
		title: "Elijah",
		description:
			"A dramatic first-person portrayal of the prophet Elijah — from the heights of Mount Carmel to the wilderness of despair and the still small voice of God. A powerful performance for conferences, retreats, and special services.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/38324834d0ffccdfaf850977f387480d77821cdb-1024x682.webp",
	},
	{
		title: "Peter",
		description:
			"Walk with Simon Peter from his first encounter with Jesus to his restoration after the resurrection. A deeply human and redemptive performance drawn directly from Scripture.",
		image:
			"https://cdn.sanity.io/images/vxczpihg/production/942aa7d8126971cf426041b33e23c0a016d850cc-1024x682.webp",
	},
];
---

<Layout
  title="Biblical Character Performances | Scripture Alive"
  description="Biblical characters brought to life — first-person performances featuring Paul, Elijah, Peter, and more."
  ogImage={"https://cdn.sanity.io/images/vxczpihg/production/5b5f24412ee24413a1313218d7f147eee363b941-1024x682.webp"}
>

  <!-- Hero -->
  <section class="py-10 px-4 bg-white text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">
        <a href="/performances" class="hover:underline">Performances</a> / Characters
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-4">
        Characters
      </h1>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed">
        Biblical characters brought to life — first-person performances that transport audiences into the world of Scripture.
      </p>
    </div>
  </section>

  <!-- Accordion Items -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-3xl mx-auto flex flex-col gap-4">
      {characters.map((character) => (
        <details class="bg-white rounded-lg shadow-sm overflow-hidden group">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none">
            <h2 class="text-lg font-bold text-gray-800 font-serif">{character.title}</h2>
            <span class="text-accent font-bold text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4">
            {character.image ? (
              <img
                src={character.image}
                alt={`${character.title} Performance`}
                loading="lazy"
                class="w-full rounded"
              />
            ) : (
              <div class="w-full h-48 bg-gray-800 rounded flex items-center justify-center">
                <span class="text-white text-lg font-semibold">{character.title}</span>
              </div>
            )}
            <p class="text-gray-600 leading-relaxed text-sm">{character.description}</p>
            <div>
              <a
                href="/book-jeremy"
                class="inline-block bg-primary text-gray-900 font-bold px-6 py-3 rounded hover:opacity-90 transition-opacity text-sm"
              >
                Book This
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-bold text-primary font-serif mb-4">
        Ready to bring Scripture to life at your event?
      </h2>
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-gray-900 font-bold px-8 py-3 rounded hover:opacity-90 transition-opacity"
      >
        Book a Performance
      </a>
    </div>
  </section>

</Layout>
