---
import Layout from "../../layouts/Layout.astro";
import { getServiceItems } from "../../utils/sanity";

const books = await getServiceItems("performances-books");
---

<Layout
  title="Books of the Bible Performances | Scripture Alive"
  description="Full books of the Bible performed word-for-word from memory — Daniel, John's Gospel, Sermon Starters, and more."
  ogImage={"https://cdn.sanity.io/images/vxczpihg/production/2f794fd31d202babdc31b4c7caea239a0cd6d45e-1024x682.png"}
>

  <!-- Back Button -->
  <div class="max-w-5xl mx-auto px-4 pt-6">
    <a href="/performances" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-700 hover:text-accent transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Performances
    </a>
  </div>

  <!-- Hero -->
  <section class="py-10 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">
        <a href="/performances" class="hover:underline">Performances</a> / Books
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-4">
        Books
      </h1>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed">
        Full books of the Bible performed word-for-word from memory — an immersive experience that brings Scripture to life.
      </p>
    </div>
  </section>

  <!-- Accordion Items -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-5xl mx-auto flex flex-col gap-4">
      {books.map((book) => (
        <details class="bg-white rounded-lg shadow-sm overflow-hidden group">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none select-none">
            <h2 class="text-lg font-bold text-gray-800 font-serif">{book.title}</h2>
            <span class="text-accent font-bold text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4">
            {book.imageUrl ? (
              <img
                src={book.imageUrl}
                alt={`${book.title} Performance`}
                loading="lazy"
                class="w-full rounded"
              />
            ) : (
              <div class="w-full h-48 bg-gray-800 rounded flex items-center justify-center">
                <span class="text-white text-lg font-semibold">{book.title}</span>
              </div>
            )}
            <p class="text-gray-600 leading-relaxed text-sm">{book.description}</p>
            <div>
              <a
                href="/book-jeremy"
                class="inline-block bg-primary text-gray-900 font-bold px-6 py-3 rounded hover:opacity-90 transition-opacity text-sm"
              >
                Book This
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4 bg-white text-center">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-primary font-serif mb-4">
        Ready to bring Scripture to life at your event?
      </h2>
      <a
        href="/book-jeremy"
        class="inline-block bg-primary text-gray-900 font-bold px-8 py-3 rounded hover:opacity-90 transition-opacity"
      >
        Book a Performance
      </a>
    </div>
  </section>

</Layout>
