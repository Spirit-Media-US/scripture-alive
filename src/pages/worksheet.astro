---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="Personal Scripture Memory Plan | Scripture Alive"
  description="Download this step-by-step worksheet to help you create your own personalized Bible memory plan."
>
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-6">Personal Scripture Memory Plan</h1>
      <p class="text-gray-700 text-lg mb-8">Download this step-by-step worksheet to help you create your own personalized Bible memory plan.</p>
      <img
        src="https://cdn.sanity.io/images/vxczpihg/production/6be4c582604d2aac4a19c30393effb34cefde179-768x512.png"
        alt="Personal Scripture Memory Plan"
        class="mx-auto rounded shadow-md mb-8 max-w-xs w-full"
        loading="lazy"
      />
      <a
        href="https://assets.spiritmediapublishing.com/scripture-alive/SA-Personal-Memorization-Plan.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white font-bold px-8 py-3 rounded text-lg hover:bg-accent/90 transition-colors"
      >
        Download Free Worksheet
      </a>
    </div>
  </section>
</Layout>
