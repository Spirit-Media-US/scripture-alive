---
import Layout from '../layouts/Layout.astro';
import { getBlogPosts } from '../utils/sanity';

const rawPosts = await getBlogPosts();

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const posts = rawPosts.map((p: any) => ({
  ...p,
  date: p.publishedAt
    ? (() => {
        const d = new Date(p.publishedAt + (p.publishedAt.length === 10 ? 'T12:00:00Z' : ''));
        return MONTHS[d.getUTCMonth()] + ' ' + d.getUTCDate() + ', ' + d.getUTCFullYear();
      })()
    : '',
  tags: p.tags || [],
  author: p.author || 'Jeremy Kluth',
  image: p.featuredImageUrl
    ? p.featuredImageUrl + '?w=800&auto=format'
    : 'https://assets.spiritmediapublishing.com/scripture-alive/scripturealive-og.png',
}));

const POSTS_JSON = JSON.stringify(posts);
---

<Layout
  title="Blog | Scripture Alive"
  description="Articles, reflections, and insights from Jeremy Kluth on Scripture memorization and living out God's Word."
>

  <!-- HERO -->
  <section class="bg-white px-6 py-12 lg:py-16 lg:px-8">
    <div class="mx-auto max-w-5xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-accent tracking-wide mb-4">
        Scripture Alive Blog
      </h1>
      <p class="text-gray-600 leading-relaxed max-w-2xl mx-auto">
        Insights, reflections, and practical tools from Jeremy Kluth to help you memorize God's Word and live it out.
      </p>
    </div>
  </section>

  <!-- SEARCH + FILTER (sticky) -->
  <section class="bg-white border-b border-gray-200 px-6 py-4 lg:px-8 sticky top-0 z-10 shadow-sm">
    <div class="mx-auto max-w-5xl flex flex-col gap-3">
      <!-- Search row -->
      <div class="flex items-center gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            id="blog-search"
            type="search"
            placeholder="Search by keyword, topic, or tag…"
            class="w-full pl-9 pr-4 py-2 rounded-lg border border-gray-300 bg-gray-50 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
          />
        </div>
        <p id="results-count" class="text-sm text-gray-500 whitespace-nowrap shrink-0"></p>
      </div>
      <!-- Filter chips -->
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider shrink-0">Filter:</span>
        <button data-tag="all" class="tag-chip active px-3 py-1 rounded-full text-xs font-semibold border transition-colors bg-accent text-white border-accent">All</button>
        <button data-tag="Scripture Memory" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Scripture Memory</button>
        <button data-tag="POWER System" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">POWER System</button>
        <button data-tag="Bible Study" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Bible Study</button>
        <button data-tag="Workshops" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Workshops</button>
        <button data-tag="Ministry" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Ministry</button>
        <button data-tag="Faith" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Faith</button>
        <button data-tag="Encouragement" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-gray-300 text-gray-600 hover:border-accent hover:text-accent transition-colors">Encouragement</button>
      </div>
    </div>
  </section>

  <!-- POSTS GRID -->
  <section class="bg-gray-50 py-12 lg:py-20 px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>

      <!-- Empty state -->
      <div id="no-results" class="hidden text-center py-20">
        <p class="text-2xl font-bold text-gray-700 mb-2">No posts found</p>
        <p class="text-gray-500 text-sm">Try a different keyword or <button onclick="clearSearch()" class="text-accent font-semibold hover:underline">clear the search</button>.</p>
      </div>

      <!-- Pagination -->
      <div id="pagination" class="mt-12 flex items-center justify-center gap-2"></div>
    </div>
  </section>

  <script id="blog-posts-data" type="application/json" set:html={POSTS_JSON}></script>
</Layout>

<script>
const POSTS = JSON.parse(document.getElementById('blog-posts-data')?.textContent || '[]');
const POSTS_PER_PAGE = 6;

let currentPage = 1;
let filteredPosts = [...POSTS];
let activeTag = 'all';
let activeSearch = '';

function applyFilters() {
  filteredPosts = POSTS.filter((p: any) => {
    const matchesTag = activeTag === 'all' || (p.tags || []).includes(activeTag);
    const q = activeSearch.toLowerCase();
    const matchesSearch = !q ||
      p.title.toLowerCase().includes(q) ||
      (p.excerpt || '').toLowerCase().includes(q) ||
      (p.tags || []).some((t: string) => t.toLowerCase().includes(q)) ||
      p.author.toLowerCase().includes(q);
    return matchesTag && matchesSearch;
  });
  currentPage = 1;
  renderPosts();
}

function renderPosts() {
  const grid = document.getElementById('posts-grid');
  const noResults = document.getElementById('no-results');
  const count = document.getElementById('results-count');
  if (!grid || !noResults || !count) return;

  const start = (currentPage - 1) * POSTS_PER_PAGE;
  const pagePosts = filteredPosts.slice(start, start + POSTS_PER_PAGE);

  if (filteredPosts.length === 0) {
    grid.innerHTML = '';
    noResults.classList.remove('hidden');
    count.textContent = '0 posts';
  } else {
    noResults.classList.add('hidden');
    count.textContent = filteredPosts.length === POSTS.length
      ? `${POSTS.length} post${POSTS.length !== 1 ? 's' : ''}`
      : `${filteredPosts.length} of ${POSTS.length} posts`;

    grid.innerHTML = pagePosts.map((post: any) => `
      <a href="/blog/${post.slug}" class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
        <div class="h-48 overflow-hidden bg-gray-200">
          <img src="${post.image}" alt="${post.title}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6 flex flex-col flex-1">
          <div class="flex flex-wrap gap-1.5 mb-3">
            ${(post.tags || []).slice(0, 2).map((t: string) => `<span class="text-xs font-semibold text-accent bg-blue-50 rounded-full px-2.5 py-0.5">${t}</span>`).join('')}
          </div>
          <h3 class="font-serif text-xl font-bold text-gray-800 mb-2 leading-snug group-hover:text-accent transition-colors">${post.title}</h3>
          <p class="text-sm text-gray-600 mb-4 leading-relaxed flex-1">${post.excerpt || ''}</p>
          <div class="flex items-center justify-between text-sm text-gray-400">
            <span>${post.author} · ${post.date}</span>
            <span class="text-accent font-semibold group-hover:underline">Read →</span>
          </div>
        </div>
      </a>
    `).join('');
  }

  renderPagination();
}

function renderPagination() {
  const pagination = document.getElementById('pagination');
  if (!pagination) return;
  const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);

  if (totalPages <= 1) { pagination.innerHTML = ''; return; }

  let html = '';
  html += `<button onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="px-4 py-2 rounded-lg border text-sm font-semibold transition-colors ${currentPage === 1 ? 'border-gray-200 text-gray-300 cursor-not-allowed' : 'border-gray-300 text-gray-600 hover:bg-gray-200'}">← Prev</button>`;
  for (let i = 1; i <= totalPages; i++) {
    html += `<button onclick="goToPage(${i})" class="w-9 h-9 rounded-lg text-sm font-semibold transition-colors ${i === currentPage ? 'bg-accent text-white' : 'border border-gray-300 text-gray-600 hover:bg-gray-200'}">${i}</button>`;
  }
  html += `<button onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="px-4 py-2 rounded-lg border text-sm font-semibold transition-colors ${currentPage === totalPages ? 'border-gray-200 text-gray-300 cursor-not-allowed' : 'border-gray-300 text-gray-600 hover:bg-gray-200'}">Next →</button>`;

  pagination.innerHTML = html;
}

(window as any).goToPage = function(page: number) {
  const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);
  if (page < 1 || page > totalPages) return;
  currentPage = page;
  renderPosts();
  document.getElementById('posts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
};

(window as any).clearSearch = function() {
  (document.getElementById('blog-search') as HTMLInputElement).value = '';
  activeSearch = '';
  activeTag = 'all';
  document.querySelectorAll('.tag-chip').forEach(b => {
    b.classList.remove('active', 'bg-accent', 'text-white', 'border-accent');
    b.classList.add('border-gray-300', 'text-gray-600');
  });
  const allBtn = document.querySelector('[data-tag="all"]');
  if (allBtn) {
    allBtn.classList.add('bg-accent', 'text-white', 'border-accent');
    allBtn.classList.remove('border-gray-300', 'text-gray-600');
  }
  applyFilters();
};

document.getElementById('blog-search')?.addEventListener('input', (e) => {
  activeSearch = (e.target as HTMLInputElement).value.trim();
  applyFilters();
});

document.querySelectorAll('.tag-chip').forEach(btn => {
  btn.addEventListener('click', () => {
    activeTag = btn.getAttribute('data-tag') || 'all';
    document.querySelectorAll('.tag-chip').forEach(b => {
      b.classList.remove('active', 'bg-accent', 'text-white', 'border-accent');
      b.classList.add('border-gray-300', 'text-gray-600');
    });
    btn.classList.add('active', 'bg-accent', 'text-white', 'border-accent');
    btn.classList.remove('border-gray-300', 'text-gray-600');
    applyFilters();
  });
});

// Initial render on page load
renderPosts();
// Re-render on Astro client-side navigation
document.addEventListener('astro:page-load', () => renderPosts());
</script>
