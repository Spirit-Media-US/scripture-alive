---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Blog | Scripture Alive"
  description="Articles, reflections, and insights from Jeremy Kluth on Scripture memorization and living out God's Word."
>

  <section class="py-14 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-accent tracking-wide mb-6">
        Blog
      </h1>
      <p class="text-gray-700 leading-relaxed max-w-2xl mx-auto">
        Articles, reflections, and insights from Jeremy Kluth on Scripture memorization and living out God's Word.
      </p>
    </div>
  </section>

  <section class="pb-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center text-gray-500">
      <p>Blog posts coming soon.</p>
    </div>
  </section>

</Layout>
