---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | Engage with Scripture Alive"
  description="Reach out and get in touch. We're here to answer your questions and engage with your insights."
  type="contact"
  ogImage="https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png"
>

  <!-- Main Contact Section -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">

      <!-- Page Heading -->
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif leading-tight">
          Get in touch with us for Booking Interests and Questions
        </h2>
      </div>

      <!-- Two column layout: left = booking info, right = form -->
      <div class="flex flex-col md:flex-row gap-10 items-start justify-center">

        <!-- Left: Booking Info + Contact Details -->
        <div class="flex flex-col gap-6 w-full max-w-sm">

          <!-- Booking Info Label -->
          <p class="text-sm font-bold uppercase tracking-widest text-primary">
            CLICK BELOW FOR BOOKING INFO
          </p>

          <!-- Booking Buttons -->
          <a
            href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Churches-Camps-Schools.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-center bg-accent text-white font-semibold text-lg px-8 py-4 rounded hover:opacity-90 transition-opacity"
          >
            Churches | Camps | Schools
          </a>

          <a
            href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Mainstage.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-center bg-accent text-white font-semibold text-lg px-8 py-4 rounded hover:opacity-90 transition-opacity"
          >
            Mainstage Performer One-Sheet
          </a>

          <!-- Contact Details -->
          <div class="mt-4 flex flex-col gap-3">
            <p class="text-base font-semibold text-gray-800">Scripture Alive</p>
            <p class="text-base text-gray-700">South Bend. IN</p>
            <p class="text-base text-gray-700">
              <a href="tel:+13126000765" class="text-primary hover:underline">
                (312) 600-0765
              </a>
            </p>
            <p class="text-base text-gray-700">
              <a href="mailto:jeremy@scripturealive.com" class="text-primary hover:underline">
                jeremy@scripturealive.com
              </a>
            </p>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="w-full max-w-2xl border border-gray-200 rounded p-6">
          <p class="text-sm text-gray-500 mb-4">"*" indicates required fields</p>

          <form
            action="https://mail.spiritmediaone.com/widget/form/yFziOIkGZbDFRUCAyFve"
            method="POST"
            class="flex flex-col gap-5"
          >
            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                name="name"
                placeholder="Full Name"
                required
                class="border border-gray-300 rounded px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>

            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Email <span class="text-red-500">*</span></label>
              <input
                type="email"
                name="email"
                placeholder="Email"
                required
                class="border border-gray-300 rounded px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>

            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Phone <span class="text-red-500">*</span></label>
              <div class="flex items-center border border-gray-300 rounded overflow-hidden">
                <span class="flex items-center gap-1 px-3 py-3 bg-gray-50 border-r border-gray-300 text-sm text-gray-600">
                  🇺🇸 ▾
                </span>
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone"
                  required
                  class="flex-1 px-4 py-3 text-sm focus:outline-none"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Message <span class="text-red-500">*</span></label>
              <textarea
                name="message"
                placeholder="Enter any additional notes or more information"
                required
                rows="4"
                class="border border-gray-300 rounded px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-8 rounded transition-colors"
            >
              Submit
            </button>
          </form>
        </div>

      </div>

    </div>
  </section>

</Layout>