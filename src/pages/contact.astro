---
import MailtoLink from "../components/MailtoLink.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Engage with Scripture Alive"
  description="Reach out and get in touch. We're here to answer your questions and engage with your insights."
  type="contact"
  ogImage="https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png"
>

  <!-- Main Contact Section -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">

      <!-- Page Heading -->
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-accent font-serif leading-tight">
          Get in touch with us for Booking Interests and Questions
        </h1>
      </div>

      <!-- Two column layout: left = booking info, right = form -->
      <div class="flex flex-col md:flex-row gap-10 items-start justify-center">

        <!-- Left: Booking Info + Contact Details -->
        <div class="flex flex-col gap-5 w-full max-w-xs">

          <!-- Booking Info Label -->
          <p class="text-sm font-bold uppercase tracking-widest text-primary">
            CLICK BELOW FOR BOOKING INFO
          </p>

          <!-- Booking Buttons -->
          <a
            href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Churches-Camps-Schools.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-center bg-accent text-white font-semibold text-base px-6 py-4 rounded hover:opacity-90 transition-opacity"
          >
            Churches | Camps | Schools
          </a>

          <a
            href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Mainstage.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-center bg-accent text-white font-semibold text-base px-6 py-4 rounded hover:opacity-90 transition-opacity"
          >
            Mainstage Performer One-Sheet
          </a>

          <!-- Contact Details -->
          <div class="mt-2 flex flex-col gap-2">
            <p class="text-base font-semibold text-gray-800">Scripture Alive</p>
            <p class="text-base text-gray-700">South Bend. IN</p>
            <a href="tel:+13126000765" class="text-primary hover:underline text-base">
              (312) 600-0765
            </a>
            <MailtoLink email="jeremy@scripturealive.com" class="text-primary hover:underline text-base">
              jeremy@scripturealive.com
            </MailtoLink>
          </div>
        </div>

        <!-- Right: Contact Form (iframe embed from GHL) -->
        <div class="w-full max-w-2xl">
          <iframe
            src="https://mail.spiritmediaone.com/widget/form/yFziOIkGZbDFRUCAyFve"
            style="width:100%;min-height:600px;border:none;border-radius:4px;"
            id="inline-yFziOIkGZbDFRUCAyFve"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-activation-type="alwaysActivated"
            data-deactivation-type="neverDeactivate"
            data-form-name="Scripture Alive Contact Form"
            data-height="600"
            data-layout-iframe-id="inline-yFziOIkGZbDFRUCAyFve"
            data-form-id="yFziOIkGZbDFRUCAyFve"
            title="Scripture Alive Contact Form"
          ></iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
        </div>

      </div>

    </div>
  </section>

</Layout>