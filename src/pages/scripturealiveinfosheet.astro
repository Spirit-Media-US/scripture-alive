---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Scripture Alive Info Sheet | Scripture Alive"
  description="Download this two-page overview of the Scripture Alive ministry — ideal for sharing with churches, camps, and schools."
>
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-6">Scripture Alive Info Sheet</h1>
      <p class="text-gray-700 text-lg mb-8">Download this two-page overview of the Scripture Alive ministry — ideal for sharing with churches, camps, and schools.</p>
      <img
        src="https://assets.spiritmediapublishing.com/scripture-alive/d0b2aceb029909de1f63dd05cb63c4af_1200_80-rdodoupx7nidwtzgvi31qpkih69etmmxm500ypsw76.webp"
        alt="Scripture Alive Info Sheet"
        class="mx-auto rounded shadow-md mb-8 max-w-xs w-full"
        loading="lazy"
      />
      <!-- TODO: Move PDF to R2 before launch if currently on WordPress -->
      <a
        href="https://scripturealive.com/wp-content/uploads/2025/05/Scripture-Alive-Info-Sheet.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-white font-bold px-8 py-3 rounded text-lg hover:bg-accent/90 transition-colors"
      >
        Download Info Sheet
      </a>
    </div>
  </section>
</Layout>
