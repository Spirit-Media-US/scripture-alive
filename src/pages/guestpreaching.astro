---
import Layout from "../layouts/Layout.astro";
import { getServiceItems } from "../utils/sanity";

const items = await getServiceItems("speaking-church-events");
---

<Layout
  title="Guest Preaching & Pulpit Fill | Scripture Alive"
  description="Be inspired by Jeremy's combination of dramatizing passages of Scriptures and preaching on them with practical and inspiring teaching."
  ogImage="https://cdn.sanity.io/images/vxczpihg/production/e43fbb6b224dc2ffef2c8abea65b96f1cea69bce-600x299.webp"
  jsonld={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Guest Preaching & Pulpit Fill",
    "url": "https://scripturealive.com/guestpreaching",
    "description": "Be inspired by Jeremy's combination of dramatizing passages of Scriptures and preaching on them with practical and inspiring teaching.",
    "about": {
      "@type": "Person",
      "name": "Jeremy Kluth",
      "jobTitle": "Speaker & Preacher",
      "worksFor": {
        "@type": "Organization",
        "name": "Scripture Alive",
        "url": "https://scripturealive.com"
      }
    }
  }}
>

  <!-- Hero / Intro Section -->
  <section class="py-12 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-accent font-display mb-4">
        Biblically-Rich Guest Speaking
      </h1>
      <p class="text-gray-700 leading-relaxed">
        Powerful spoken messages for churches, chapels, camps, and podcasts —
        often paired with live Scripture performance and personal storytelling.
      </p>
    </div>
  </section>

  {items.map((item: any, i: number) => {
    const imageFirst = i % 2 === 0;
    const imageBlock = (
      <div class="w-full md:w-5/12">
        <img
          src={item.imageUrl}
          alt={item.title}
          class="w-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
          decoding="async"
        />
      </div>
    );
    const textBlock = (
      <div class="w-full md:w-7/12">
        <h2 class="text-xl font-bold text-gray-800 font-serif mb-3">
          {item.title}
        </h2>
        <p class="text-gray-700 leading-relaxed">
          {item.description}
        </p>
      </div>
    );
    return (
      <section class="py-8 px-4 bg-white">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col md:flex-row gap-6 items-start">
            {imageFirst ? imageBlock : textBlock}
            {imageFirst ? textBlock : imageBlock}
          </div>
        </div>
      </section>
    );
  })}

  <!-- Invite Jeremy CTA -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <a
        href="/contact"
        class="inline-block bg-accent text-white font-serif font-semibold px-8 py-3 rounded hover:bg-accent/85 transition-colors"
      >
        Invite Jeremy
      </a>
    </div>
  </section>

</Layout>