---
import Layout from '../layouts/Layout.astro';
import { getEvents } from '../utils/sanity';

const title = "Upcoming Events | Scripture Alive Ministry";
const description = "Stay updated with the latest events, sessions, and gatherings by Scripture Alive.";
const ogImage = "https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png";

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";

const allEvents = await getEvents();
const now = new Date();
const upcomingEvents = allEvents.filter((e: any) => new Date(e.startDate) >= now);
const pastEvents = allEvents.filter((e: any) => new Date(e.startDate) < now);

// Group upcoming events by month/year
function groupByMonth(events: any[]) {
  const groups: Record<string, any[]> = {};
  for (const e of events) {
    const d = new Date(e.startDate);
    const key = d.toLocaleString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
    if (!groups[key]) groups[key] = [];
    groups[key].push(e);
  }
  return groups;
}

const upcomingGroups = groupByMonth(upcomingEvents);

function fmtDay(dateStr: string, endDateStr?: string) {
  const start = new Date(dateStr);
  const startDay = start.getUTCDate();
  if (endDateStr) {
    const end = new Date(endDateStr);
    const endDay = end.getUTCDate();
    if (startDay !== endDay) return `${startDay}–${endDay}`;
  }
  return String(startDay);
}

function fmtMonth(dateStr: string) {
  return new Date(dateStr).toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
}

function fmtTime(startStr: string, endStr?: string) {
  const fmt = (s: string) => new Date(s).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC' });
  if (!endStr) return fmt(startStr);
  return `${fmt(startStr)} – ${fmt(endStr)}`;
}
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  type="events"
>

  <!-- Page Hero -->
  <section class="bg-primary py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-white font-serif mb-4">Upcoming Events</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        Stay updated with the latest events, sessions, and gatherings by Scripture Alive.
      </p>
    </div>
  </section>

  <!-- Booking Info Strip -->
  <section class="bg-cream border-y border-gray-200 py-8 px-4">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-center gap-6 text-center">
      <p class="text-gray-700 font-semibold text-lg">Download our booking information sheets:</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Churches-Camps-Schools.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-semibold hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Churches, Camps &amp; Schools
        </a>
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Mainstage.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Mainstage Productions
        </a>
      </div>
    </div>
  </section>

  <!-- Event Calendar Section -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif mb-3">Event Calendar</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Join us at one of our upcoming performances, workshops, or guest speaking engagements. Scripture Alive brings the Word to life in churches, camps, schools, and mainstage venues across the country.
        </p>
      </div>

      <!-- Event Cards (static marketing) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/b935343b78a571e3a47c0bcf57790708_1200_80-1024x576.webp`}
              alt="Scripture Alive Performance"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Performance</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-serif mb-2">Live Scripture Performance</h3>
            <p class="text-gray-600 text-sm flex-1 mb-4">
              Experience the Bible brought to life through dramatic performance. Scripture Alive presents powerful, memorized Scripture presentations that engage and inspire audiences of all ages.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-primary text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-primary/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/6865005301c79a6751a57ebf4f16d840_1200_80-1024x768.webp`}
              alt="Scripture Alive Workshop"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Workshop</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-serif mb-2">Scripture Memorization Workshop</h3>
            <p class="text-gray-600 text-sm flex-1 mb-4">
              Learn the art and discipline of Scripture memorization. Jeremy Walker shares practical techniques for memorizing and presenting God's Word with passion and accuracy.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-accent text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-accent/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-1024x759.webp`}
              alt="Scripture Alive"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-serif mb-2">Scripture Alive</h3>
            <p class="text-gray-600 text-sm flex-1 mb-4">
              Scripture Alive brings the living Word of God to life through dramatic performance and Scripture memorization training for churches, camps, schools, and mainstage venues.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-primary text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-primary/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

      </div>

      <!-- Upcoming Events from Sanity -->
      <div class="mt-4">

        {Object.keys(upcomingGroups).length === 0 && (
          <p class="text-center text-gray-500 py-8">No upcoming events at this time. Check back soon!</p>
        )}

        {Object.entries(upcomingGroups).map(([month, events]) => (
          <div>
            <h2 class="text-2xl font-bold text-gray-800 font-serif mb-4 mt-8 pb-2 border-b border-gray-200">{month}</h2>
            {events.map((event: any) => (
              <div class="flex gap-4 md:gap-6 py-5 border-b border-gray-100 items-start">
                <div class="flex-shrink-0 w-14 text-center">
                  <div class="text-xs font-bold text-gray-500 uppercase">{fmtMonth(event.startDate)}</div>
                  <div class="text-3xl font-bold text-primary leading-none">{fmtDay(event.startDate, event.endDate)}</div>
                </div>
                <div class="flex-1">
                  <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">
                    {event.workshopIncluded === 'yes' ? `${event.performance} & Workshop` : 'Performance'}
                  </div>
                  <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1">
                    {event.performance}{event.workshopIncluded === 'yes' ? ' & Workshop' : ''}: {event.venueName} - {event.venueCity}, {event.venueState}
                  </h3>
                  <div class="flex flex-wrap gap-4 text-xs text-gray-500">
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {fmtTime(event.startDate, event.endDate)}
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {event.venueName}
                    </span>
                    {event.bookingUrl && (
                      <a href={event.bookingUrl} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Details →</a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))}

        {pastEvents.length > 0 && (
          <div>
            <h2 class="text-2xl font-bold text-gray-800 font-serif mb-4 mt-10 pb-2 border-b border-gray-200">Past Events</h2>
            {pastEvents.slice(0, 5).map((event: any) => (
              <div class="flex gap-4 md:gap-6 py-5 border-b border-gray-100 items-start opacity-60">
                <div class="flex-shrink-0 w-14 text-center">
                  <div class="text-xs font-bold text-gray-500 uppercase">{fmtMonth(event.startDate)}</div>
                  <div class="text-3xl font-bold text-gray-400 leading-none">{fmtDay(event.startDate, event.endDate)}</div>
                </div>
                <div class="flex-1">
                  <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">
                    {event.workshopIncluded === 'yes' ? 'Performance & Workshop' : 'Performance'}
                  </div>
                  <h3 class="text-base md:text-lg font-bold text-gray-700 mb-1">
                    {event.performance}{event.workshopIncluded === 'yes' ? ' & Workshop' : ''}: {event.venueName} - {event.venueCity}, {event.venueState}
                  </h3>
                  <div class="text-xs text-gray-400">{fmtTime(event.startDate, event.endDate)} · {event.venueName}</div>
                </div>
              </div>
            ))}
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- Book CTA -->
  <section class="py-12 px-4 bg-cream text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent mb-4">Interested in Booking Jeremy?</h2>
      <p class="text-gray-600 mb-6">Contact us to check availability and discuss bringing Scripture Alive to your church, camp, school, or event.</p>
      <a href="/contact" class="inline-block bg-primary text-black font-semibold px-8 py-3 rounded hover:opacity-90 transition-opacity">
        Get in Touch
      </a>
    </div>
  </section>

</Layout>
