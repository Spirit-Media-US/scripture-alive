---
import Layout from "../layouts/Layout.astro";
import { getEvents } from "../utils/sanity";

const title = "Events Calendar | Scripture Alive Ministry";
const description =
	"Join us at one of our upcoming performances, workshops, or guest speaking engagements. Scripture Alive brings the Word to life in churches, camps, schools, and mainstage venues across the country.";
const ogImage =
	"https://cdn.sanity.io/images/vxczpihg/production/3817274e4a92fe337ca32760afefbb8391395ed7-1768x891.png";

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";

const allEvents = await getEvents();
const now = new Date();
const upcomingEvents = allEvents.filter(
	(e: any) => new Date(e.startDate) >= now,
);
const pastEvents = allEvents.filter((e: any) => new Date(e.startDate) < now);

// Group upcoming events by month/year
function groupByMonth(events: any[]) {
	const groups: Record<string, any[]> = {};
	for (const e of events) {
		const d = new Date(e.startDate);
		const key = d.toLocaleString("en-US", {
			month: "long",
			year: "numeric",
			timeZone: "UTC",
		});
		if (!groups[key]) groups[key] = [];
		groups[key].push(e);
	}
	return groups;
}

const upcomingGroups = groupByMonth(upcomingEvents);

function fmtDay(dateStr: string, endDateStr?: string) {
	const start = new Date(dateStr);
	const startDay = start.getUTCDate();
	if (endDateStr) {
		const end = new Date(endDateStr);
		const endDay = end.getUTCDate();
		if (startDay !== endDay) return `${startDay}–${endDay}`;
	}
	return String(startDay);
}

function fmtMonth(dateStr: string) {
	return new Date(dateStr)
		.toLocaleString("en-US", { month: "short", timeZone: "UTC" })
		.toUpperCase();
}

function fmtTime(startStr: string, endStr?: string) {
	const fmt = (s: string) =>
		new Date(s).toLocaleTimeString("en-US", {
			hour: "numeric",
			minute: "2-digit",
			hour12: true,
			timeZone: "UTC",
		});
	if (!endStr) return fmt(startStr);
	return `${fmt(startStr)} - ${fmt(endStr)}`;
}

function fmtFullDate(startStr: string, endStr?: string) {
	const opts: Intl.DateTimeFormatOptions = { month: 'long', day: 'numeric', timeZone: 'UTC' };
	const start = new Date(startStr).toLocaleDateString('en-US', opts);
	if (!endStr) return start;
	const startDay = new Date(startStr).getUTCDate();
	const endDay = new Date(endStr).getUTCDate();
	if (startDay === endDay) return start;
	return `${start} - ${new Date(endStr).toLocaleDateString('en-US', opts)}`;
}
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  type="events"
  jsonld={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Events Calendar | Scripture Alive Ministry",
    "url": "https://scripturealive.com/events",
    "description": "Join us at one of our upcoming performances, workshops, or guest speaking engagements.",
    "about": {
      "@type": "Organization",
      "name": "Scripture Alive",
      "url": "https://scripturealive.com"
    }
  }}
>

  <!-- 1) Events Calendar Heading -->
  <section class="bg-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-accent font-display mb-4">Events Calendar</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Join us at one of our upcoming performances, workshops, or guest speaking engagements. Scripture Alive brings the Word to life in churches, camps, schools, and mainstage venues across the country.
      </p>
    </div>
  </section>

  <!-- 2) Download Booking Info -->
  <section class="bg-cream border-y border-gray-200 py-8 px-4">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-center gap-6 text-center">
      <p class="text-gray-700 font-semibold text-lg">Download our booking information sheets:</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Churches-Camps-Schools.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Churches, Camps &amp; Schools
        </a>
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Mainstage.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Mainstage Productions
        </a>
      </div>
    </div>
  </section>

  <!-- 3) Month/Event Listings with Descriptions -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-4xl mx-auto">

      {Object.keys(upcomingGroups).length === 0 && (
        <p class="text-center text-gray-500 py-8">No upcoming events at this time. Check back soon!</p>
      )}

      {Object.entries(upcomingGroups).map(([month, events]) => (
        <div>
          <h2 class="text-2xl font-bold text-gray-800 mb-6 mt-8 pb-2 border-b border-gray-200" style="font-family: 'Roboto Slab', Georgia, serif;">{month}</h2>
          {events.map((event: any) => (
            <div
              class="mb-8 pb-8 border-b border-gray-100 cursor-pointer hover:bg-gray-50 rounded-lg px-4 py-4 transition-colors"
              data-event={JSON.stringify({
                performance: event.performance,
                workshopIncluded: event.workshopIncluded,
                venueName: event.venueName,
                venueCity: event.venueCity,
                venueState: event.venueState,
                venueAddress: event.venueAddress ?? '',
                startDate: event.startDate,
                endDate: event.endDate,
                bookingUrl: event.bookingUrl ?? '',
                eventSubtitle: event.eventSubtitle ?? '',
                tags: event.tags ?? [],
                description: event.description ?? ''
              })}
              role="button"
              tabindex="0"
            >
              <!-- Event Type Label -->
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">
                {event.workshopIncluded === 'yes' ? `Performance & Workshop` : 'Performance'}
              </div>

              <!-- Event Title -->
              <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3 font-sans">
                {event.performance}{event.workshopIncluded === 'yes' ? ' & Workshop' : ''}: {event.venueName} - {event.venueCity}, {event.venueState}
              </h3>

              <!-- Tags -->
              {event.tags && event.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-3">
                  {event.tags.map((tag: string) => (
                    <span class="text-xs text-gray-500">{tag}</span>
                  ))}
                </div>
              )}

              <!-- When & Where -->
              <div class="flex flex-col sm:flex-row gap-6 text-sm">
                <div>
                  <div class="font-bold text-gray-800 flex items-center gap-2 mb-1">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    WHEN
                  </div>
                  <div class="text-gray-700">{fmtFullDate(event.startDate, event.endDate)} {fmtTime(event.startDate, event.endDate)}</div>
                  <a
                    href={`https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(event.performance + ' – ' + event.venueName)}&dates=${new Date(event.startDate).toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '')}/${event.endDate ? new Date(event.endDate).toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '') : new Date(event.startDate).toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '')}&location=${encodeURIComponent((event.venueAddress || '') + ' ' + event.venueCity + ', ' + event.venueState)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent text-xs hover:underline font-semibold"
                  >
                    Add to Calendar
                  </a>
                </div>
                <div>
                  <div class="font-bold text-gray-800 flex items-center gap-2 mb-1">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    WHERE
                  </div>
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent((event.venueAddress || '') + ' ' + event.venueName + ' ' + event.venueCity + ', ' + event.venueState)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:underline"
                  >
                    {event.venueName}
                  </a>
                  <div class="text-gray-500">{event.venueAddress ? `${event.venueAddress}, ` : ''}{event.venueCity}, {event.venueState}</div>
                  <a
                    href={`https://www.google.com/maps/dir//${encodeURIComponent((event.venueAddress || '') + ' ' + event.venueName + ' ' + event.venueCity + ', ' + event.venueState)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent text-xs hover:underline font-semibold"
                  >
                    Get Directions
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      ))}

      {pastEvents.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-gray-800 mb-4 mt-10 pb-2 border-b border-gray-200" style="font-family: 'Roboto Slab', Georgia, serif;">Past Events</h2>
          {pastEvents.slice(0, 5).map((event: any) => (
            <div class="flex gap-4 md:gap-6 py-5 border-b border-gray-100 items-start opacity-60">
              <div class="flex-shrink-0 w-14 text-center">
                <div class="text-xs font-bold text-gray-500 uppercase">{fmtMonth(event.startDate)}</div>
                <div class="text-3xl font-bold text-gray-400 leading-none">{fmtDay(event.startDate, event.endDate)}</div>
              </div>
              <div class="flex-1">
                <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">
                  {event.workshopIncluded === 'yes' ? 'Performance & Workshop' : 'Performance'}
                </div>
                <h3 class="text-base md:text-lg font-bold text-gray-700 mb-1 font-sans">
                  {event.performance}{event.workshopIncluded === 'yes' ? ' & Workshop' : ''}: {event.venueName} - {event.venueCity}, {event.venueState}
                </h3>
                <div class="text-xs text-gray-400">{fmtTime(event.startDate, event.endDate)} · {event.venueName}</div>
              </div>
            </div>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- 4) Performance / Workshop / Speaking CTA Cards -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={"https://cdn.sanity.io/images/vxczpihg/production/da0764f78c42eac49abd6c968a0ac4e505546fc0-1024x576.webp"}
              alt="Scripture Alive Performance"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Performance</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-sans mb-2">Live Scripture Performance</h3>
            <p class="text-gray-600 flex-1 mb-4">
              Experience the Bible brought to life through dramatic performance. Scripture Alive presents powerful, memorized Scripture presentations that engage and inspire audiences of all ages.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-accent text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-accent/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={"https://cdn.sanity.io/images/vxczpihg/production/0d09808dd1e4a9bff945b742d454abf57c0a65f3-1200x900.webp"}
              alt="Scripture Alive Workshop"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Workshop</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-sans mb-2">Scripture Memorization Workshop</h3>
            <p class="text-gray-600 flex-1 mb-4">
              Learn the art and discipline of Scripture memorization. Jeremy shares practical techniques for memorizing and presenting God's Word with passion and accuracy.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-accent text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-accent/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={"https://cdn.sanity.io/images/vxczpihg/production/95f6eca3784e25f56fab50d2b06c8245915244ac-1024x759.webp"}
              alt="Scripture Alive Speaking"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-gold text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Speaking</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-sans mb-2">Guest Speaking</h3>
            <p class="text-gray-600 flex-1 mb-4">
              Guest speaking, radio/podcast interviews, coaching, and more.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-accent text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-accent/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Event Popup Modal -->
  <div id="event-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60" role="dialog" aria-modal="true">
    <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full p-6 relative max-h-[90vh] overflow-y-auto">
      <button id="modal-close" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 text-2xl leading-none" aria-label="Close">&times;</button>

      <div id="modal-type" class="text-xs font-bold uppercase tracking-wider text-accent mb-3"></div>
      <h2 id="modal-title" class="text-xl font-bold text-gray-900 font-serif mb-4"></h2>
      <div id="modal-subtitle" class="text-sm text-gray-500 mb-2"></div>
      <div id="modal-tags" class="flex flex-wrap gap-1.5 mb-4"></div>
      <div class="mb-4">
        <p id="modal-description" class="text-gray-600 leading-relaxed text-sm overflow-hidden transition-all duration-300" style="max-height: 4.5em;"></p>
        <button id="modal-show-more" class="text-accent text-xs font-semibold mt-1 hover:underline hidden">Show more</button>
      </div>

      <div class="space-y-6 text-sm">
        <!-- When -->
        <div>
          <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">When</div>
          <div class="flex items-start gap-2 text-gray-700">
            <svg class="w-4 h-4 mt-0.5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <div>
              <div id="modal-date"></div>
              <div id="modal-time" class="text-gray-500"></div>
            </div>
          </div>
          <div class="mt-2">
            <a id="modal-cal-link" href="#" class="text-xs text-accent hover:underline font-semibold">+ Add to Calendar</a>
          </div>
        </div>

        <!-- Where -->
        <div>
          <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Where</div>
          <div class="flex items-start gap-2 text-gray-700">
            <svg class="w-4 h-4 mt-0.5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div>
              <div id="modal-venue"></div>
              <div id="modal-address" class="text-gray-500"></div>
            </div>
          </div>
          <div class="mt-4">
            <a id="modal-directions" href="#" target="_blank" rel="noopener noreferrer" class="text-xs text-accent hover:underline font-semibold">Get Directions</a>
          </div>
          <div class="mt-4 rounded overflow-hidden" style="height:200px;">
            <iframe id="modal-map" src="" width="100%" height="200" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Event location map"></iframe>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 mb-6">
        <a id="modal-booking-link" href="/contact" class="flex-1 text-center bg-accent text-white font-semibold px-6 py-4 rounded hover:opacity-90 transition-opacity">Book Jeremy for Your Event</a>
      </div>

      <!-- Share options -->
      <div class="border-t border-gray-100 pt-6">
        <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Share</div>
        <div class="flex flex-wrap gap-3">
          <button id="modal-copy-link" class="flex items-center gap-1.5 text-xs text-gray-600 hover:text-accent font-semibold border border-gray-200 rounded px-3 py-1.5 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <span id="modal-copy-label">Copy Link</span>
          </button>
          <a id="modal-share-email" href="#" class="flex items-center gap-1.5 text-xs text-gray-600 hover:text-accent font-semibold border border-gray-200 rounded px-3 py-1.5 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Invite via Email
          </a>
          <a id="modal-share-facebook" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs text-gray-600 hover:text-accent font-semibold border border-gray-200 rounded px-3 py-1.5 transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073C24 5.406 18.627 0 12 0S0 5.406 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047v-2.66c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.265h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
            Facebook
          </a>
          <a id="modal-share-x" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-xs text-gray-600 hover:text-accent font-semibold border border-gray-200 rounded px-3 py-1.5 transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const modal = document.getElementById('event-modal')!;
    const modalClose = document.getElementById('modal-close')!;

    function fmtDate(startStr: string, endStr?: string) {
      const opts: Intl.DateTimeFormatOptions = { weekday: 'long', month: 'long', day: 'numeric', timeZone: 'UTC' };
      const start = new Date(startStr).toLocaleDateString('en-US', opts);
      if (!endStr) return start;
      const endDay = new Date(endStr).getUTCDate();
      const startDay = new Date(startStr).getUTCDate();
      if (startDay === endDay) return start;
      return `${start} – ${new Date(endStr).toLocaleDateString('en-US', { day: 'numeric', month: 'long', timeZone: 'UTC' })}`;
    }

    function fmtTime(startStr: string, endStr?: string) {
      const fmt = (s: string) => new Date(s).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC' });
      if (!endStr) return fmt(startStr);
      return `${fmt(startStr)} – ${fmt(endStr)}`;
    }

    function makeCalLink(event: any) {
      const pad = (n: number) => String(n).padStart(2, '0');
      const dt = (s: string) => {
        const d = new Date(s);
        return `${d.getUTCFullYear()}${pad(d.getUTCMonth()+1)}${pad(d.getUTCDate())}T${pad(d.getUTCHours())}${pad(d.getUTCMinutes())}00Z`;
      };
      const start = dt(event.startDate);
      const end = event.endDate ? dt(event.endDate) : start;
      const title = encodeURIComponent(`${event.performance} – ${event.venueName}`);
      const loc = encodeURIComponent(`${event.venueName}, ${event.venueCity}, ${event.venueState}`);
      return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${start}/${end}&location=${loc}`;
    }

    function openModal(event: any) {
      const isWorkshop = event.workshopIncluded === 'yes' || event.workshopIncluded === 'workshop';
      document.getElementById('modal-type')!.textContent = isWorkshop ? 'Performance & Workshop' : 'Performance';
      document.getElementById('modal-title')!.textContent = `${event.performance}${isWorkshop ? ' & Workshop' : ''}: ${event.venueName} - ${event.venueCity}, ${event.venueState}`;

      const subtitle = document.getElementById('modal-subtitle')!;
      subtitle.textContent = event.eventSubtitle || '';
      subtitle.style.display = event.eventSubtitle ? '' : 'none';

      const tagsEl = document.getElementById('modal-tags')!;
      tagsEl.innerHTML = '';
      if (event.tags && event.tags.length > 0) {
        event.tags.forEach((tag: string) => {
          const span = document.createElement('span');
          span.textContent = tag;
          span.className = 'text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full';
          tagsEl.appendChild(span);
        });
        tagsEl.style.display = 'flex';
      } else {
        tagsEl.style.display = 'none';
      }

      const desc = document.getElementById('modal-description')!;
      const showMoreBtn = document.getElementById('modal-show-more')!;
      desc.textContent = event.description || '';
      desc.parentElement!.style.display = event.description ? '' : 'none';
      desc.style.maxHeight = '4.5em';
      showMoreBtn.textContent = 'Show more';
      // Show button only if text overflows
      requestAnimationFrame(() => {
        if (desc.scrollHeight > desc.clientHeight + 2) {
          showMoreBtn.classList.remove('hidden');
        } else {
          showMoreBtn.classList.add('hidden');
        }
      });

      document.getElementById('modal-date')!.textContent = fmtDate(event.startDate, event.endDate);
      document.getElementById('modal-time')!.textContent = fmtTime(event.startDate, event.endDate);
      document.getElementById('modal-venue')!.textContent = event.venueName;

      const addr = document.getElementById('modal-address')!;
      addr.textContent = event.venueAddress || `${event.venueCity}, ${event.venueState}`;

      const directions = document.getElementById('modal-directions') as HTMLAnchorElement;
      const mapsQuery = encodeURIComponent(event.venueAddress || `${event.venueName} ${event.venueCity} ${event.venueState}`);
      directions.href = `https://www.google.com/maps/dir//${mapsQuery}`;

      const mapFrame = document.getElementById('modal-map') as HTMLIFrameElement;
      mapFrame.src = `https://www.google.com/maps?q=${mapsQuery}&output=embed`;

      // Share links
      const pageUrl = encodeURIComponent(window.location.href);
      const shareTitle = encodeURIComponent(`${event.performance} – ${event.venueName}, ${event.venueCity} ${event.venueState}`);
      const emailBody = encodeURIComponent(`Check out this event: ${event.performance} at ${event.venueName} in ${event.venueCity}, ${event.venueState}.\n\n${window.location.href}`);
      (document.getElementById('modal-share-email') as HTMLAnchorElement).href = `mailto:?subject=${shareTitle}&body=${emailBody}`;
      (document.getElementById('modal-share-facebook') as HTMLAnchorElement).href = `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`;
      (document.getElementById('modal-share-x') as HTMLAnchorElement).href = `https://x.com/intent/tweet?text=${shareTitle}&url=${pageUrl}`;

      (document.getElementById('modal-cal-link') as HTMLAnchorElement).href = makeCalLink(event);

      const bookingLink = document.getElementById('modal-booking-link') as HTMLAnchorElement;
      if (event.bookingUrl) {
        bookingLink.href = event.bookingUrl;
        bookingLink.target = '_blank';
        bookingLink.rel = 'noopener noreferrer';
        bookingLink.textContent = 'Get Tickets';
      } else {
        bookingLink.href = '/contact';
        bookingLink.removeAttribute('target');
        bookingLink.textContent = 'Book Jeremy for Your Event';
      }

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-event]').forEach(el => {
      el.addEventListener('click', () => openModal(JSON.parse((el as HTMLElement).dataset.event!)));
      el.addEventListener('keydown', (e: Event) => {
        if ((e as KeyboardEvent).key === 'Enter') openModal(JSON.parse((el as HTMLElement).dataset.event!));
      });
    });

    // Share buttons
    document.getElementById('modal-copy-link')!.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const label = document.getElementById('modal-copy-label')!;
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy Link'; }, 2000);
      });
    });

    // Show more / less toggle
    document.getElementById('modal-show-more')!.addEventListener('click', () => {
      const desc = document.getElementById('modal-description')!;
      const btn = document.getElementById('modal-show-more')!;
      if (desc.style.maxHeight === '4.5em') {
        desc.style.maxHeight = 'none';
        btn.textContent = 'Show less';
      } else {
        desc.style.maxHeight = '4.5em';
        btn.textContent = 'Show more';
      }
    });

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  </script>

  <!-- 5) Interested in Booking Jeremy? -->
  <section class="py-12 px-4 bg-cream text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-accent mb-4">Interested in Booking Jeremy?</h2>
      <p class="text-gray-600 mb-6">Contact us to check availability and discuss bringing Scripture Alive to your church, camp, school, or event.</p>
      <a href="/contact" class="inline-block bg-accent text-white font-semibold px-8 py-3 rounded hover:opacity-90 transition-opacity">
        Get in Touch
      </a>
    </div>
  </section>

</Layout>
