---
import Layout from '../layouts/Layout.astro';

const title = "Upcoming Events | Scripture Alive Ministry";
const description = "Stay updated with the latest events, sessions, and gatherings by Scripture Alive.";
const ogImage = "https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png";

const BASE = "https://assets.spiritmediapublishing.com/scripture-alive";
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  type="events"
>

  <!-- Page Hero -->
  <section class="bg-primary py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-white font-[Lora] mb-4">Upcoming Events</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        Stay updated with the latest events, sessions, and gatherings by Scripture Alive.
      </p>
    </div>
  </section>

  <!-- Booking Info Strip -->
  <section class="bg-[#f5f0e8] border-y border-gray-200 py-8 px-4">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-center gap-6 text-center">
      <p class="text-gray-700 font-semibold text-lg">Download our booking information sheets:</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Churches-Camps-Schools.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-semibold hover:bg-primary/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Churches, Camps &amp; Schools
        </a>
        <a
          href="https://assets.spiritmediapublishing.com/scripture-alive/Scripture-Alive-One-Sheet-Mainstage.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Mainstage Productions
        </a>
      </div>
    </div>
  </section>

  <!-- Event Calendar Section -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-[Lora] mb-3">Event Calendar</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Join us at one of our upcoming performances, workshops, or guest speaking engagements. Scripture Alive brings the Word to life in churches, camps, schools, and mainstage venues across the country.
        </p>
      </div>

      <!-- Event Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">

        <!-- Card 1: Performance -->
        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/b935343b78a571e3a47c0bcf57790708_1200_80-1024x576.webp`}
              alt="Scripture Alive Performance"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Performance</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-[Lora] mb-2">Live Scripture Performance</h3>
            <p class="text-gray-600 text-sm flex-1 mb-4">
              Experience the Bible brought to life through dramatic performance. Scripture Alive presents powerful, memorized Scripture presentations that engage and inspire audiences of all ages.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-primary text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-primary/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <!-- Card 2: Workshop -->
        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/6865005301c79a6751a57ebf4f16d840_1200_80-1024x768.webp`}
              alt="Scripture Alive Workshop"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Workshop</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 font-[Lora] mb-2">Scripture Memorization Workshop</h3>
            <p class="text-gray-600 text-sm flex-1 mb-4">
              Learn the art and discipline of Scripture memorization. Jeremy Walker shares practical techniques for memorizing and presenting God's Word with passion and accuracy.
            </p>
            <a href="/contact" class="mt-auto inline-block text-center bg-accent text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-accent/90 transition-colors">
              Book This Event
            </a>
          </div>
        </div>

        <!-- Card 3: Scripture Alive -->
        <div class="rounded-2xl overflow-hidden shadow-md border border-gray-100 flex flex-col">
          <div class="relative overflow-hidden">
            <img
              src={`${BASE}/672f0ecbb7fdae63f0f38d8a68af1122_1200_80-1024x759.webp`}
