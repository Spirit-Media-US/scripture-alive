---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Dramatic Scripture Videos | Scripture Alive"
  description="Witness Scripture come alive through dramatic performances."
  type="media"
  ogImage="https://scripturealive.com/wp-content/uploads/2023/11/scripturealive.png"
>

  <!-- Page Heading -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif">
        Check Out Jeremy Kluth's Scripture Performances
      </h2>
    </div>
  </section>

  <!-- Video 1: Daniel 3 – Image of Gold and the Blazing Furnace -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1082916797?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Watch a 2-minute sample of Jeremy dramatically presenting The Image of Gold and the Blazing Furnace from Daniel 3.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/94DuyD5tHOg"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 2: Acts 9 – Paul on the Road to Damascus -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
