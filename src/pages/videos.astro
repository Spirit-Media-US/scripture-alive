---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Dramatic Scripture Videos | Scripture Alive"
  description="Witness Scripture come alive through dramatic performances."
  type="media"
  ogImage="https://assets.spiritmediapublishing.com/scripture-alive/scripturealive-og.png"
>

  <!-- Page Heading -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-primary font-serif">
        Check Out Jeremy Kluth's Scripture Performances
      </h1>
    </div>
  </section>

  <!-- Video 1: Daniel 3 – Image of Gold and the Blazing Furnace -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1082916797?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Watch a 2-minute sample of Jeremy dramatically presenting The Image of Gold and the Blazing Furnace from Daniel 3.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/94DuyD5tHOg"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 2: Acts 9 – Paul on the Road to Damascus -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1082959146?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Jeremy portrays Paul the Apostle (formerly Saul) on the road to Damascus in this 3-minute scene from Acts 9.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/T9sS8yFVu0M"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 3: John 11 – Jesus Raising Lazarus -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1083962636?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Check out this 2-minute scene from Jeremy's performance of Jesus Raising Lazarus from John 11.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/YHn8Mn9A8kw"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 4: One-Man Passion Play – Peter's Denial -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1084255629?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Jeremy presents his One-Man Passion Play, an original blended harmony of the passion account in the Gospels covering the Last Supper through Jesus' crucifixion. This sample includes Peter's denial after Jesus is arrested.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/xnvOmK8ah1g"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 5: Elijah & the Widow (Vimeo 1084273212) -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2">
          <div class="relative w-full aspect-video">
            <iframe
              class="absolute inset-0 w-full h-full rounded shadow-lg"
              src="https://player.vimeo.com/video/1084273212?color&autopause=0&loop=0&muted=0&title=0&portrait=0&byline=0"
              allowfullscreen
              allow="clipboard-write"
              title="vimeo Video Player"
            ></iframe>
          </div>
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-primary font-serif">
            Experience this impactful 2-minute scene from Jeremy's performance of Elijah &amp; the Widow from 1 Kings 17.
          </h2>
          <h2 class="text-base md:text-lg font-bold font-serif">
            <a
              href="https://youtu.be/_hJFok97gvk"
              target="_blank"
              rel="noopener"
              class="text-accent hover:underline uppercase"
            >
              CLICK HERE FOR THE FULL PERFORMANCE
            </a>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <!-- Video 6: YouTube – 1 Samuel 17: David & Goliath -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="relative w-full aspect-video">
        <iframe
          class="absolute inset-0 w-full h-full rounded shadow-lg"
          src="https://www.youtube.com/embed/wh_znWMYXiI"
          title="1 Samuel 17: David &amp; Goliath - Jeremy Kluth | Scripture Alive"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Video 7: YouTube – Job 1-2: The Testing of Job -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="relative w-full aspect-video">
        <iframe
          class="absolute inset-0 w-full h-full rounded shadow-lg"
          src="https://www.youtube.com/embed/xvtG5wu4jtA"
          title="Job 1-2: The Testing of Job - Jeremy Kluth | Scripture Alive"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Video 8: YouTube – Luke 1: The Birth of John the Baptist Foretold -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="relative w-full aspect-video">
        <iframe
          class="absolute inset-0 w-full h-full rounded shadow-lg"
          src="https://www.youtube.com/embed/YG4_BiWNuUE"
          title="Luke 1: The Birth of John the Baptist Foretold - Jeremy Kluth | Scripture Alive"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

</Layout>